---
import ArticleCard from "@components/blog/articleCard.astro";

const { articulos, tagByArticleKey } = Astro.props as {
  articulos: any[];
  tagByArticleKey?: Map<string, string> | null;
};

const list = Array.isArray(articulos) ? articulos : [];
const total = list.length;
const prefixId = "RelacionadosMovil";
---

{
  total > 0 && (
    <section
      class="sliderArticulosRelacionados w-full max-w-7xl mx-auto px-0 py-4"
      aria-labelledby={`${prefixId}-heading`}
    >
      <h2 id={`${prefixId}-heading`} class="blog-article-related-heading px-0">
        Relacionados
      </h2>

      <div class="w-full">
        <div
          class="glide js-article-related-slider w-full"
          data-prefixid={prefixId}
          data-total-items={String(total)}
        >
          <div class="glide__track" data-glide-el="track">
            <ul class="glide__slides">
              {list.map((articulo: any) => (
                <li class="glide__slide h-full">
                  <div class="group relative flex h-full min-h-[340px] flex-col overflow-hidden rounded-[16px]">
                    <ArticleCard article={articulo} tagByArticleKey={tagByArticleKey} />
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      {/* Misma fila que `slideArticles.astro` (home / vitrina blog) */}
      <div class="mt-4 flex flex-row flex-nowrap items-center justify-between gap-4">
        <a href="/blog" class="medrent-btn-primary group h-fit shrink-0">
          <span class="hidden min-[440px]:inline">Ver más artículos</span>
          <span class="inline min-[440px]:hidden">Ver más</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path
              d="M17.9199 6.62C17.8185 6.37565 17.6243 6.18147 17.3799 6.08C17.2597 6.02876 17.1306 6.00158 16.9999 6H6.99994C6.73472 6 6.48037 6.10536 6.29283 6.29289C6.1053 6.48043 5.99994 6.73478 5.99994 7C5.99994 7.26522 6.1053 7.51957 6.29283 7.70711C6.48037 7.89464 6.73472 8 6.99994 8H14.5899L6.28994 16.29C6.19621 16.383 6.12182 16.4936 6.07105 16.6154C6.02028 16.7373 5.99414 16.868 5.99414 17C5.99414 17.132 6.02028 17.2627 6.07105 17.3846C6.12182 17.5064 6.19621 17.617 6.28994 17.71C6.3829 17.8037 6.4935 17.8781 6.61536 17.9289C6.73722 17.9797 6.86793 18.0058 6.99994 18.0058C7.13195 18.0058 7.26266 17.9797 7.38452 17.9289C7.50638 17.8781 7.61698 17.8037 7.70994 17.71L15.9999 9.41V17C15.9999 17.2652 16.1053 17.5196 16.2928 17.7071C16.4804 17.8946 16.7347 18 16.9999 18C17.2652 18 17.5195 17.8946 17.707 17.7071C17.8946 17.5196 17.9999 17.2652 17.9999 17V7C17.9984 6.86932 17.9712 6.74022 17.9199 6.62Z"
              fill="white"
            />
          </svg>
        </a>

        <div
          id={`controls-${prefixId}`}
          class="flex shrink-0 items-center justify-center gap-4"
        >
          <button
            id={`prev-btn-${prefixId}`}
            type="button"
            aria-label="Anterior"
            class="prevBtn group flex h-[32px] w-[56px] cursor-pointer items-center justify-center rounded-full border border-black bg-white transition hover:bg-black"
          >
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              class="fill-current text-black transition group-hover:text-white"
              aria-hidden="true"
            >
              <path
                d="M17 11H9.41l3.3-3.29a1 1 0 10-1.42-1.42L6.29 11.29a1 1 0 000 1.42l5 5a1 1 0 001.42-1.42L9.41 13H17a1 1 0 000-2z"
                fill="currentColor"
              />
            </svg>
          </button>
          <span
            id={`contador-${prefixId}`}
            class="min-w-[72px] text-center text-base font-semibold"
          >
            1 / 1
          </span>
          <button
            id={`next-btn-${prefixId}`}
            type="button"
            aria-label="Siguiente"
            class="nextBtn group flex h-[32px] w-[56px] cursor-pointer items-center justify-center rounded-full border border-black bg-white transition hover:bg-black"
          >
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              class="fill-current text-black transition group-hover:text-white"
              aria-hidden="true"
            >
              <path
                d="M7 11h7.59l-3.3-3.29a1 1 0 111.42-1.42l5 5a1 1 0 010 1.42l-5 5a1 1 0 11-1.42-1.42L14.59 13H7a1 1 0 010-2z"
                fill="currentColor"
              />
            </svg>
          </button>
        </div>
      </div>
    </section>
  )
}

<script>
  const initArticleRelatedSliders = async () => {
    const { default: Glide } = await import("@glidejs/glide");
    document.querySelectorAll(".js-article-related-slider[data-prefixid]").forEach((el) => {
      if (!(el instanceof HTMLElement) || el.dataset.mounted === "true") return;
      el.dataset.mounted = "true";

      const prefixId = el.dataset.prefixid;
      if (!prefixId) return;
      const totalItems = Number(el.dataset.totalItems || 0);

      const glider = new Glide(el, {
        type: "slider",
        bound: true,
        perView: 2,
        gap: 16,
        dragThreshold: 80,
        swipeThreshold: 80,
        startAt: 0,
        breakpoints: {
          767: { perView: 1, gap: 12 },
        },
      }) as any;

      const contador = document.getElementById(`contador-${prefixId}`);
      const controls = document.getElementById(`controls-${prefixId}`);
      const prevBtn = document.getElementById(`prev-btn-${prefixId}`);
      const nextBtn = document.getElementById(`next-btn-${prefixId}`);

      function getSlidesToShow() {
        return window.innerWidth < 768 ? 1 : 2;
      }

      function updateContador() {
        if (!contador) return;
        const total = totalItems;
        const slidesToShow = getSlidesToShow();
        const totalPages = Math.max(1, Math.ceil(total / slidesToShow));
        const currentIndex = glider.index;
        const lastStart = Math.max(0, total - slidesToShow);
        const currentPage =
          currentIndex >= lastStart
            ? totalPages
            : Math.min(totalPages, Math.floor(currentIndex / slidesToShow) + 1);
        contador.textContent = `${currentPage} / ${totalPages}`;

        if (controls) {
          const isMobileViewport = window.innerWidth < 768;
          const shouldShowControls = isMobileViewport ? total > 1 : total > slidesToShow;
          controls.style.display = shouldShowControls ? "" : "none";
        }
      }

      prevBtn?.addEventListener("click", (e) => {
        e.preventDefault();
        const perView = getSlidesToShow();
        glider.go(`=${Math.max(0, glider.index - perView)}`);
      });

      nextBtn?.addEventListener("click", (e) => {
        e.preventDefault();
        const perView = getSlidesToShow();
        const lastStart = Math.max(0, totalItems - perView);
        glider.go(`=${Math.min(lastStart, glider.index + perView)}`);
      });

      glider.on("run.after", updateContador);
      glider.on("mount.after", updateContador);
      window.addEventListener("resize", updateContador);
      window.addEventListener("orientationchange", updateContador);
      glider.mount();
      updateContador();
    });
  };

  const run = () => {
    initArticleRelatedSliders().catch(() => {});
  };
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", run, { once: true });
  } else {
    run();
  }
</script>

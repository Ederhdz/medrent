---
const { articulos } = Astro.props;
import ArticleCard from '@components/blog/ArticleCard.astro';
//console.log('Artículos cargados:', articulos);
---

<div id="glider-articulosRelacionados" class="glider" style="flex-basis: 100%;">
{articulos && articulos.map((articulo: any, index: number) => (
    <div class="glider-slide flex-shrink-0 h-full" style="height:100%">
        <div class="group rounded-[16px] overflow-hidden relative flex-shrink-0 h-full min-h-[340px] flex flex-col" style="height:100%">
            <ArticleCard article={articulo} />
        </div>
    </div>
))}
</div>

<div class="flex flex-row justify-between items-center mt-6">
    <a href={ '/blog'} class="bg-[var(--color-primary)] flex justify-center cursor-pointer items-center gap-2 self-stretch px-4 py-[14px] rounded-[4px] border border-[#261819] text-white text-base transition-colors group text-[14px] h-fit" >
      <span class="hidden min-[440px]:inline">Ver más artículos</span>
      <span class="inline min-[440px]:hidden">Ver más</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
        <path d="M17.9199 6.62C17.8185 6.37565 17.6243 6.18147 17.3799 6.08C17.2597 6.02876 17.1306 6.00158 16.9999 6H6.99994C6.73472 6 6.48037 6.10536 6.29283 6.29289C6.1053 6.48043 5.99994 6.73478 5.99994 7C5.99994 7.26522 6.1053 7.51957 6.29283 7.70711C6.48037 7.89464 6.73472 8 6.99994 8H14.5899L6.28994 16.29C6.19621 16.383 6.12182 16.4936 6.07105 16.6154C6.02028 16.7373 5.99414 16.868 5.99414 17C5.99414 17.132 6.02028 17.2627 6.07105 17.3846C6.12182 17.5064 6.19621 17.617 6.28994 17.71C6.3829 17.8037 6.4935 17.8781 6.61536 17.9289C6.73722 17.9797 6.86793 18.0058 6.99994 18.0058C7.13195 18.0058 7.26266 17.9797 7.38452 17.9289C7.50638 17.8781 7.61698 17.8037 7.70994 17.71L15.9999 9.41V17C15.9999 17.2652 16.1053 17.5196 16.2928 17.7071C16.4804 17.8946 16.7347 18 16.9999 18C17.2652 18 17.5195 17.8946 17.707 17.7071C17.8946 17.5196 17.9999 17.2652 17.9999 17V7C17.9984 6.86932 17.9712 6.74022 17.9199 6.62Z" fill="white"/>
      </svg>
    </a>

    <div class="flex items-center gap-[24px] border-[var(--color-primary)] border-2 rounded-full flex px-4 py-3 justify-center items-center gap-6">
      <div id="controls-articulosRelacionados" class="botones-glider flex justify-start gap-4 w-full md:w-auto">
        <button id="prev-btn-articulosRelacionados" aria-label="Anterior"  class="prevBtn group flex items-center justify-center w-[56px] h-[32px] text-black transition-colors cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M7.825 13L13.425 18.6L12 20L4 12L12 4L13.425 5.4L7.825 11H20V13H7.825Z" fill="#006764"/>
          </svg>
        </button>
        <label  id="contador-articulosRelacionados" class="eventos-label text-black text-center font-kallisto text-[16px] font-light tracking-[2.5px]">1/{articulos?.length || 0}</label>
        <button id="next-btn-articulosRelacionados" aria-label="Siguiente" class="nextBtn group flex items-center justify-center w-[56px] h-[32px] transition-colors cursor-pointer">
         <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M16.175 13H4V11H16.175L10.575 5.4L12 4L20 12L12 20L10.575 18.6L16.175 13Z" fill="#006764"/>
        </svg>
        </button>
      </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const el = document.getElementById('glider-articulosRelacionados');
        if (!el) return;

        const glider = new Glider(el, {
          rewind: true,
          slidesToShow: 1,
          slidesToScroll: 1,
          draggable: true,
          duration: .5,
          arrows: {
            prev: '#prev-btn-articulosRelacionados',
            next: '#next-btn-articulosRelacionados'
          },
          responsive: [
            { breakpoint: 0, settings: { slidesToShow: 1 } },
            { breakpoint: 768, settings: { slidesToShow: 2 } },
            { breakpoint: 1024, settings: { slidesToShow: 3 } }
          ]
        });
        
        function getSlidesToShow() {
          const width = window.innerWidth;
          if (width < 768) return 1;
          if (width < 1024) return 2;
          return 3;
        }
        
        const contador = document.getElementById('contador-articulosRelacionados');
        const controls = document.getElementById('controls-articulosRelacionados');
        
        function updateContador() {
          if (contador && glider) {
            if (controls) {
              if (window.innerWidth < 1000) {
                controls.classList.add('order-4');
                controls.style.flexWrap = 'wrap';
                controls.style.width = '100%';
                controls.style.justifyContent = 'center';
              } else {
                controls.classList.remove('order-4');
                controls.style.flexWrap = '';
                controls.style.width = '';
                controls.style.justifyContent = '';
              }
            }
            
            const total = glider.slides.length;
            const slideActual = glider.slide + 1;
            
            contador.textContent = `${slideActual} / ${total}`;
            
            if (controls) {
              const slidesToShow = getSlidesToShow();
              if (total > slidesToShow) {
                controls.style.display = '';
              } else {
                controls.style.display = 'none';
              }
            }
          }
        }
        
        updateContador();
        el.addEventListener('glider-slide-visible', updateContador);
        el.addEventListener('glider-animated', updateContador);
        el.addEventListener('glider-refresh', updateContador);
        window.addEventListener('resize', updateContador);
        window.addEventListener('orientationchange', updateContador);
    });
</script>
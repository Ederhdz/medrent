---
const { articulos } = Astro.props;
import ArticleCard from '@components/blog/articleCard.astro';
//console.log('Artículos cargados:', articulos);
---

<div class="w-full">
  <div id="blog-vitrina-articulos" data-prefixid="BlogArticulos" data-total-items={String(articulos?.length || 0)} class="glide js-blog-slider w-full">
    <div class="glide__track" data-glide-el="track">
      <ul class="glide__slides">
        {articulos && articulos.map((articulo: any) => (
          <li class="glide__slide h-full">
            <div class="group rounded-[16px] overflow-hidden relative h-full min-h-[340px] flex flex-col">
              <ArticleCard article={articulo} />
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</div>

<div class="flex flex-row justify-between items-center gap-4 mt-6 flex-nowrap">
    <a href={ '/blog'} class="medrent-btn-primary h-fit shrink-0 group" >
      <span class="hidden min-[440px]:inline">Ver más artículos</span>
      <span class="inline min-[440px]:hidden">Ver más</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
        <path d="M17.9199 6.62C17.8185 6.37565 17.6243 6.18147 17.3799 6.08C17.2597 6.02876 17.1306 6.00158 16.9999 6H6.99994C6.73472 6 6.48037 6.10536 6.29283 6.29289C6.1053 6.48043 5.99994 6.73478 5.99994 7C5.99994 7.26522 6.1053 7.51957 6.29283 7.70711C6.48037 7.89464 6.73472 8 6.99994 8H14.5899L6.28994 16.29C6.19621 16.383 6.12182 16.4936 6.07105 16.6154C6.02028 16.7373 5.99414 16.868 5.99414 17C5.99414 17.132 6.02028 17.2627 6.07105 17.3846C6.12182 17.5064 6.19621 17.617 6.28994 17.71C6.3829 17.8037 6.4935 17.8781 6.61536 17.9289C6.73722 17.9797 6.86793 18.0058 6.99994 18.0058C7.13195 18.0058 7.26266 17.9797 7.38452 17.9289C7.50638 17.8781 7.61698 17.8037 7.70994 17.71L15.9999 9.41V17C15.9999 17.2652 16.1053 17.5196 16.2928 17.7071C16.4804 17.8946 16.7347 18 16.9999 18C17.2652 18 17.5195 17.8946 17.707 17.7071C17.8946 17.5196 17.9999 17.2652 17.9999 17V7C17.9984 6.86932 17.9712 6.74022 17.9199 6.62Z" fill="white"/>
      </svg>
    </a>

    <div id="controls-BlogArticulos" class="flex items-center gap-4 justify-center shrink-0">
        <button id="prev-btn-BlogArticulos" aria-label="Anterior" class="prevBtn group flex items-center justify-center w-[56px] h-[32px] rounded-full bg-white border border-black cursor-pointer transition hover:bg-black">
          <svg width="24" height="24" viewBox="0 0 24 24" class="fill-current text-black transition group-hover:text-white">
            <path d="M17 11H9.41l3.3-3.29a1 1 0 10-1.42-1.42L6.29 11.29a1 1 0 000 1.42l5 5a1 1 0 001.42-1.42L9.41 13H17a1 1 0 000-2z" fill="currentColor"/>
          </svg>
        </button>
        <span id="contador-BlogArticulos" class="font-semibold text-base min-w-[72px] text-center">1 / 1</span>
        <button id="next-btn-BlogArticulos" aria-label="Siguiente" class="nextBtn group flex items-center justify-center w-[56px] h-[32px] rounded-full bg-white border border-black cursor-pointer transition hover:bg-black">
         <svg width="24" height="24" viewBox="0 0 24 24" class="fill-current text-black transition group-hover:text-white">
          <path d="M7 11h7.59l-3.3-3.29a1 1 0 111.42-1.42l5 5a1 1 0 010 1.42l-5 5a1 1 0 11-1.42-1.42L14.59 13H7a1 1 0 010-2z" fill="currentColor"/>
        </svg>
        </button>
    </div>
</div>

<script>
const initBlogSliders = async () => {
  const { default: Glide } = await import('@glidejs/glide');
  document.querySelectorAll('.js-blog-slider[data-prefixid]').forEach((el) => {
    if (el.dataset.mounted === 'true') return;
    el.dataset.mounted = 'true';

    const prefixId = el.dataset.prefixid;
    const totalItems = Number(el.dataset.totalItems || 0);
    const isDesktop = window.innerWidth >= 1024;
    const glider = new Glide(el, {
      rewind: false,
      type: 'slider',
      bound: true,
      perView: 3,
      gap: 24,
      dragThreshold: isDesktop ? false : 80,
      swipeThreshold: isDesktop ? false : 80,
      startAt: 0,
      breakpoints: {
        1024: { perView: 2, gap: 16 },
        768: { perView: 1, gap: 12 }
      }
    });

    const contador = document.getElementById(`contador-${prefixId}`);
    const controls = document.getElementById(`controls-${prefixId}`);
    const prevBtn = document.getElementById(`prev-btn-${prefixId}`);
    const nextBtn = document.getElementById(`next-btn-${prefixId}`);

    function getSlidesToShow() {
      const width = window.innerWidth;
      if (width < 768) return 1;
      if (width < 1024) return 2;
      return 3;
    }

    function updateContador() {
      if (!contador) return;
      const total = totalItems;
      const slidesToShow = getSlidesToShow();
      const totalPages = Math.max(1, Math.ceil(total / slidesToShow));
      const currentIndex = glider.index;
      const lastStart = Math.max(0, total - slidesToShow);
      const currentPage = currentIndex >= lastStart
        ? totalPages
        : Math.min(totalPages, Math.floor(currentIndex / slidesToShow) + 1);
      contador.textContent = `${currentPage} / ${totalPages}`;

      if (controls) {
        const isMobileViewport = window.innerWidth < 768;
        const shouldShowControls = isMobileViewport
          ? total > 1
          : total > slidesToShow;
        controls.style.display = shouldShowControls ? '' : 'none';
      }
    }

    prevBtn?.addEventListener('click', (event) => {
      event.preventDefault();
      const perView = getSlidesToShow();
      const target = Math.max(0, glider.index - perView);
      glider.go(`=${target}`);
    });

    nextBtn?.addEventListener('click', (event) => {
      event.preventDefault();
      const perView = getSlidesToShow();
      const total = totalItems;
      const lastStart = Math.max(0, total - perView);
      const target = Math.min(lastStart, glider.index + perView);
      glider.go(`=${target}`);
    });

    glider.on('run.after', updateContador);
    glider.on('mount.after', updateContador);
    window.addEventListener('resize', updateContador);
    window.addEventListener('orientationchange', updateContador);
    glider.mount();
    updateContador();
  });
};

const safeInitBlogSlider = () => {
  initBlogSliders().catch(() => {});
};

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', safeInitBlogSlider, { once: true });
} else {
  safeInitBlogSlider();
}
</script>
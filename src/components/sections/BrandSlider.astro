---
import ImageResponsive from "@components/media/ImageResponsive.astro";
type BrandItem = {
  slug?: string;
  name?: string;
  logo?: any;
};
const { marcasData = [] } = Astro.props as { marcasData?: BrandItem[] };
---

<section class="max-w-7xl mx-auto py-16">
  <div class="text-center p-6">
    <h3 class="text-[var(--color-accent)] font-bold text-[14px] md:text-[14px] uppercase text-center">
      NUESTRAS MARCAS
    </h3>
    <h2 class="text-[24px] font-bold text-[var(--color-text-default)] tracking-tight">
      ¡Representamos marcas líderes a nivel mundial!
    </h2>
    <p class="text-[var(--color-green-dark)] text-base tracking-[0.5px]">
      Trabajamos directamente con las mejores marcas para ofrecer equipos confiables, duraderos y clínicamente validados
    </p>
  </div>

  <div class="relative w-full overflow-hidden">
    <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-24 bg-gradient-to-r from-white to-transparent"></div>
    <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-24 bg-gradient-to-l from-white to-transparent"></div>
    
     {marcasData.length > 0 ? (
      <div class="glide" id="BrandSlider">
        <div class="glide__track" data-glide-el="track">
          <ul class="glide__slides">
            {marcasData.map((brand: BrandItem) => (
              <li class="glide__slide flex justify-center items-center p-6" style="width: 158px;">
                <a href={'nuestras-marcas/' + brand.slug || '#'} class="hover-scale-img block">
                  <ImageResponsive
                    image={brand.logo}
                    alt={brand.name}
                    class="h-[40px] w-auto object-contain"
                    loading="lazy"
                    decoding="async"
                    sizes="158px"
                    fetchpriority="low"
                  />
                </a>
              </li>
            ))}
          </ul>
        </div>

        {/* <div data-glide-el="controls">
          <button data-glide-dir="<" aria-label="Anterior" class="group flex items-center justify-center w-[56px] h-[32px] rounded-full bg-white border border-black cursor-pointer transition hover:bg-black lg:hidden">
            <svg width="24" height="24" viewBox="0 0 24 24" class="fill-current text-black transition group-hover:text-white">
              <path d="M17 11H9.41l3.3-3.29a1 1 0 10-1.42-1.42L6.29 11.29a1 1 0 000 1.42l5 5a1 1 0 001.42-1.42L9.41 13H17a1 1 0 000-2z" fill="currentColor"/>
            </svg>
          </button>
          <button data-glide-dir=">" aria-label="Siguiente" class="group flex items-center justify-center w-[56px] h-[32px] rounded-full bg-white border border-black cursor-pointer transition hover:bg-black lg:hidden">
            <svg width="24" height="24" viewBox="0 0 24 24" class="fill-current text-black transition group-hover:text-white">
              <path d="M7 11h7.59l-3.3-3.29a1 1 0 111.42-1.42l5 5a1 1 0 010 1.42l-5 5a1 1 0 11-1.42-1.42L14.59 13H7a1 1 0 010-2z" fill="currentColor"/>
            </svg>
          </button>
        </div> */}

      </div>
    ) : (
      <p class="text-center text-gray-500">No hay marcas disponibles</p>
    )}
  </div>
</section>



<script>
  (function () {
    const slider = document.querySelector('#BrandSlider') as HTMLElement | null;
    if (!slider || slider.dataset.mounted === 'true') return;
    let glide: { mount: () => void; play: () => void; pause: () => void } | null = null;
    let visibilityObserver: IntersectionObserver | null = null;

    const mount = async () => {
      if (slider.dataset.mounted === 'true') return;
      const Glide = (await import('@glidejs/glide')).default;
      glide = new Glide(slider, {
        type: 'carousel',
        perView: 8,
        gap: 0,
        autoplay: 2000,
        animationDuration: 500,
        animationTimingFunc: 'linear',
        hoverpause: true,
        breakpoints: {
          1024: { perView: 4 },
          640: { perView: 2 }
        }
      });
      glide.mount();
      slider.dataset.mounted = 'true';

      if ('IntersectionObserver' in window && glide) {
        visibilityObserver = new IntersectionObserver((entries) => {
          const isVisible = entries.some((entry) => entry.isIntersecting);
          if (isVisible) {
            glide?.play();
          } else {
            glide?.pause();
          }
        }, { threshold: 0.05 });
        visibilityObserver.observe(slider);
      }
    };

    const scheduleMount = () => {
      if ('requestIdleCallback' in window) {
        window.requestIdleCallback(() => mount().catch(() => {}));
      } else {
        setTimeout(() => mount().catch(() => {}), 0);
      }
    };

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        const isVisible = entries.some((entry) => entry.isIntersecting);
        if (isVisible) {
          observer.disconnect();
          scheduleMount();
        }
      }, { rootMargin: '300px 0px' });
      observer.observe(slider);
    } else {
      scheduleMount();
    }
  })();
</script>

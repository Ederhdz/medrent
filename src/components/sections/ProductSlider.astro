---
const { data, title, prefixId } = Astro.props;
import ProductCard from '@components/product/ProductCard.astro';
---
{data && data.length > 0 && (
    <section class="max-w-7xl mx-auto py-8">
        <div class="botones-glider flex justify-between gap-6 w-full md:w-auto" style="flex-wrap: wrap; position: relative;">
            <h2 class=" text-[28px] font-bold text-[var(--color-text-default)] w-full md:w-auto">
              {title}
            </h2>
            
            {data.length > 4 && (
              <div id={`controls-${prefixId}`} class="flex gap-4 items-center" >
                <button aria-label="Anterior" class={`prev-btn-${prefixId} group flex items-center justify-center w-[56px] h-[32px] rounded-full bg-white border border-black cursor-pointer transition hover:bg-black`}>
                <svg width="24" height="24" viewBox="0 0 24 24" class="fill-current text-black transition group-hover:text-white">
                  <path d="M17 11H9.41l3.3-3.29a1 1 0 10-1.42-1.42L6.29 11.29a1 1 0 000 1.42l5 5a1 1 0 001.42-1.42L9.41 13H17a1 1 0 000-2z" fill="currentColor"/>
                </svg>
                </button>
                <span id={`contador-${prefixId}`} class="font-semibold text-base min-w-[48px] text-center">1 / {data.length}</span>
                <button aria-label="Siguiente" class={`next-btn-${prefixId} group flex items-center justify-center w-[56px] h-[32px] rounded-full bg-white border border-black cursor-pointer transition hover:bg-black`}>
                <svg width="24" height="24" viewBox="0 0 24 24" class="fill-current text-black transition group-hover:text-white">
                  <path d="M7 11h7.59l-3.3-3.29a1 1 0 111.42-1.42l5 5a1 1 0 010 1.42l-5 5a1 1 0 11-1.42-1.42L14.59 13H7a1 1 0 010-2z" fill="currentColor"/>
                </svg>
                </button>
              </div>
            )}
            <div id={`${prefixId}-vitrinaProductCard`}  data-prefixid={`${prefixId}`}  class="glide">
                <div class="glide__track" data-glide-el="track">
                    <div class="glide__slides">
                        {data.map((product:any) => (
                            <ProductCard product={product} ></ProductCard>
                        ))}
                    </div>
                </div>
            </div>
        </div>
    </section>
)}


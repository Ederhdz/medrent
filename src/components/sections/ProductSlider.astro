---
const { data, title, prefixId } = Astro.props;
const { disableHorizontalPadding = false } = Astro.props;
import ProductCard from '@components/product/ProductCard.astro';
---
{data && data.length > 0 && (
    <section class={`max-w-7xl mx-auto py-6 md:py-6 ${disableHorizontalPadding ? 'px-0' : 'px-4 md:px-8'}`}>
        <div class="botones-glider flex justify-between gap-6 w-full" style="flex-wrap: wrap; position: relative;">
            <h2 class=" text-[28px] font-bold text-[var(--color-text-default)] w-full md:w-auto">
              {title}
            </h2>
            
            {data.length > 1 && (
              <div id={`controls-${prefixId}`} class="flex gap-4 items-center" data-glide-el="controls">
                <button
                  type="button"
                  aria-label="Anterior"
                  data-glide-dir="<"
                  class={`prev-btn-${prefixId} group flex items-center justify-center w-[56px] h-[32px] rounded-full bg-white border border-black cursor-pointer transition hover:bg-black`}
                >
                <svg width="24" height="24" viewBox="0 0 24 24" class="fill-current text-black transition group-hover:text-white">
                  <path d="M17 11H9.41l3.3-3.29a1 1 0 10-1.42-1.42L6.29 11.29a1 1 0 000 1.42l5 5a1 1 0 001.42-1.42L9.41 13H17a1 1 0 000-2z" fill="currentColor"/>
                </svg>
                </button>
                <span id={`contador-${prefixId}`} class="font-semibold text-base min-w-[72px] text-center">1 / 1</span>
                <button
                  type="button"
                  aria-label="Siguiente"
                  data-glide-dir=">"
                  class={`next-btn-${prefixId} group flex items-center justify-center w-[56px] h-[32px] rounded-full bg-white border border-black cursor-pointer transition hover:bg-black`}
                >
                <svg width="24" height="24" viewBox="0 0 24 24" class="fill-current text-black transition group-hover:text-white">
                  <path d="M7 11h7.59l-3.3-3.29a1 1 0 111.42-1.42l5 5a1 1 0 010 1.42l-5 5a1 1 0 11-1.42-1.42L14.59 13H7a1 1 0 010-2z" fill="currentColor"/>
                </svg>
                </button>
              </div>
            )}
            <div
              id={`${prefixId}-vitrinaProductCard`}
              data-prefixid={`${prefixId}`}
              data-total-items={String(data.length)}
              class="glide js-product-slider w-full"
            >
                <div class="glide__track" data-glide-el="track">
                    <ul class="glide__slides">
                        {data.map((product:any) => (
                            <li class="glide__slide">
                              <ProductCard product={product} />
                            </li>
                        ))}
                    </ul>
                </div>
            </div>
        </div>
    </section>
)}


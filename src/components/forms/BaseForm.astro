      </svg>

      <div class="flex flex-col items-center gap-2">
        <h3 class="uppercase text-base font-medium text-[var(--color-primary)]">SOLICITUD ENVIADA</h3>
        <h2 class="text-xl font-semibold text-[24px] font-bold">{successTitle}</h2>
        <p class="text-gray-600">{successText}</p>
        <p class="text-gray-600 font-bold">Si tu requerimiento es urgente, también puedes comunicarte directamente con nuestro equipo comercial.</p>
      </div>

      <a
        href="https://wa.me/525559854347"
        type="button"
        class="retry-btn bg-[#FFF] text-[var(--color-primary)] px-6 py-3 rounded border-3 border-[var(--color-primary)] cursor-pointer transition hover:bg-[var(--color-secondary-light)] flex gap-2"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M12.0011 2.00006C17.5241 2.00006 22.0011 6.47706 22.0011 12.0001C22.0011 17.5231 17.5241 22.0001 12.0011 22.0001C10.2339 22.0031 8.4977 21.5354 6.97111 20.6451L2.00511 22.0001L3.35711 17.0321C2.46607 15.505 1.99802 13.7681 2.00111 12.0001C2.00111 6.47706 6.47812 2.00006 12.0011 2.00006ZM8.59311 7.30006L8.39311 7.30806C8.2638 7.31697 8.13746 7.35093 8.02111 7.40806C7.91269 7.46957 7.81368 7.54636 7.72711 7.63606C7.60711 7.74906 7.53911 7.84706 7.46611 7.94206C7.09624 8.42296 6.89709 9.01337 6.90011 9.62006C6.90211 10.1101 7.03011 10.5871 7.23011 11.0331C7.63911 11.9351 8.31211 12.8901 9.20011 13.7751C9.41411 13.9881 9.62411 14.2021 9.85011 14.4011C10.9535 15.3725 12.2684 16.073 13.6901 16.4471L14.2581 16.5341C14.4431 16.5441 14.6281 16.5301 14.8141 16.5211C15.1053 16.5057 15.3896 16.4269 15.6471 16.2901C15.778 16.2224 15.9058 16.149 16.0301 16.0701C16.0301 16.0701 16.0724 16.0414 16.1551 15.9801C16.2901 15.8801 16.3731 15.8091 16.4851 15.6921C16.5691 15.6054 16.6391 15.5047 16.6951 15.3901C16.7731 15.2271 16.8511 14.9161 16.8831 14.6571C16.9071 14.4591 16.9001 14.3511 16.8971 14.2841C16.8931 14.1771 16.8041 14.0661 16.7071 14.0191L16.1251 13.7581C16.1251 13.7581 15.2551 13.3791 14.7231 13.1371C14.6674 13.1128 14.6078 13.0989 14.5471 13.0961C14.4787 13.0889 14.4095 13.0965 14.3443 13.1185C14.2791 13.1404 14.2193 13.176 14.1691 13.2231C14.1641 13.2211 14.0971 13.2781 13.3741 14.1541C13.3326 14.2098 13.2755 14.252 13.2099 14.2751C13.1444 14.2983 13.0734 14.3014 13.0061 14.2841C12.9409 14.2667 12.8771 14.2446 12.8151 14.2181C12.6911 14.1661 12.6481 14.1461 12.5631 14.1101C11.989 13.86 11.4576 13.5215 10.9881 13.1071C10.8621 12.9971 10.7451 12.8771 10.6251 12.7611C10.2317 12.3843 9.88886 11.958 9.60511 11.4931L9.54611 11.3981C9.50438 11.3339 9.47015 11.2651 9.44411 11.1931C9.40611 11.0461 9.50511 10.9281 9.50511 10.9281C9.50511 10.9281 9.74811 10.6621 9.86111 10.5181C9.97111 10.3781 10.0641 10.2421 10.1241 10.1451C10.2421 9.95506 10.2791 9.76006 10.2171
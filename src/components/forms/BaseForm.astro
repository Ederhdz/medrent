        </svg>
        Contactar ahora
      </a>

    </div>
  </div>

  <!-- ERROR -->
  <div class="form-error hidden">
    <div class="bg-[#FFF8F7] rounded-3xl pt-12 pr-6 pb-8 pl-6 text-center flex flex-col items-center gap-4">
      <svg xmlns="http://www.w3.org/2000/svg" width="84" height="84" viewBox="0 0 84 84" fill="none">
        <path d="M61.25 46.41C65.3036 46.4434 69.243 45.0686 72.3956 42.5202C75.5481 39.9719 77.7182 36.4082 78.5352 32.4377C79.3522 28.4671 78.7655 24.3361 76.8752 20.7502C74.9849 17.1642 71.9083 14.3456 68.1709 12.7759C64.4334 11.2062 60.267 10.9826 56.383 12.1434C52.4991 13.3043 49.1386 15.7774 46.8755 19.1406C44.6123 22.5037 43.587 26.5482 43.9744 30.5834C44.3619 34.6185 46.1382 38.394 49 41.265C52.2482 44.5237 56.6491 46.3721 61.25 46.41ZM68.67 36.33C67.1363 37.8515 65.1705 38.8628 63.0409 39.2261C60.9113 39.5894 58.7214 39.287 56.77 38.36L70.77 24.36C71.7042 26.3267 72.004 28.5351 71.6277 30.6797C71.2515 32.8242 70.2179 34.7988 68.67 36.33ZM53.83 21.49C55.7972 19.5203 58.4662 18.4124 61.25 18.41C62.8026 18.4245 64.3327 18.7831 65.73 19.46L51.73 33.46C50.7958 31.4933 50.496 29.2848 50.8723 27.1403C51.2485 24.9958 52.2821 23.0212 53.83 21.49ZM71.75 49.91C70.8217 49.91 69.9315 50.2787 69.2751 50.9351C68.6188 51.5915 68.25 52.4817 68.25 53.41V67.41C68.25 68.3383 67.8813 69.2285 67.2249 69.8849C66.5685 70.5412 65.6783 70.91 64.75 70.91H15.75C14.8217 70.91 13.9315 70.5412 13.2751 69.8849C12.6187 69.2285 12.25 68.3383 12.25 67.41V33.845L32.83 54.425C34.7887 56.3861 37.4433 57.4933 40.215 57.505C41.6244 57.5087 43.0201 57.2286 44.3189 56.6814C45.6178 56.1342 46.7931 55.3311 47.775 54.32C48.4058 53.6674 48.7585 52.7952 48.7585 51.8875C48.7585 50.9798 48.4058 50.1076 47.775 49.455C47.449 49.1216 47.0598 48.8568 46.63 48.6759C46.2003 48.4951 45.7387 48.4019 45.2725 48.4019C44.8063 48.4019 44.3447 48.4951 43.915 48.6759C43.4852 48.8568 43.096 49.1216 42.77 49.455C42.1158 50.0963 41.2361 50.4555 40.32 50.4555C39.4039 50.4555 38.5243 50.0963 37.87 49.455L17.185 28.91H33.25C34.1783 28.91 35.0685 28.5412 35.7249 27.8849C36.3813 27.2285 36.75 26.3383 36.75 25.41C36.75 24.4817 36.3813 23.5915 35.7249 22.9351C35.0685 22.2787 34.1783 21.91 33.25 21.91H15.75C12.9652 21.91 10.2945 23.0162 8.32538 24.9854C6.35625 26.9545 5.25 29.6252 5.25 32.41V67.41C5.25 70.1948 6.35625 72.8655 8.3
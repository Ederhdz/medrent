---
// src/components/forms/BaseForm.astro
const {
  id,
  class: className = "",
  successTitle = "Gracias por contactarnos.",
  successText = "Tu solicitud ha sido registrada y un asesor especializado se comunicará contigo en las próximas horas para brindarte asesoría personalizada.",
  errorTitle = "No fue posible enviar la solicitud",
  errorText = "Estamos teniendo un inconveniente temporal."
} = Astro.props;
---

<div id={`${id}-wrapper`} class="form-wrapper relative">

  <!-- FORM -->
  <div class="form-container">
    <form id={id} class={className}>
      <slot />
    </form>
  </div>

  <!-- SUCCESS -->
  <div class="form-success hidden">
    <div class="bg-[#F5FAF9] rounded-3xl pt-12 pr-6 pb-8 pl-6 text-center flex flex-col items-center gap-4">
      <svg xmlns="http://www.w3.org/2000/svg" width="84" height="84" viewBox="0 0 84 84" fill="none">

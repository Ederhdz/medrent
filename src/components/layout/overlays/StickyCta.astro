---
const pathname = Astro.url.pathname;
const isPDP = pathname.startsWith('/productos/');
const pathSegments = pathname.split('/').filter(Boolean);
const isEspecialidadCuartoNivel = pathSegments[0] === 'especialidades' && pathSegments.length === 4;
const isMarcaProducto = pathSegments[0] === 'nuestras-marcas' && pathSegments.length === 3;
const hideButton = isPDP || isEspecialidadCuartoNivel || isMarcaProducto;
---


{!hideButton && (
<div id="BtnWhatsappDemo" class="fixed bottom-0 left-0 right-0 z-50" style="background: #00201F; box-shadow: 0 20px 24px -4px rgba(49,48,48,0.10), 0 6px 8px -4px rgba(49,48,48,0.04);">
    <!-- Misma caja que la fila del Navbar: max-w-7xl + px-4/md:px-8/xl:px-10 -->
    <div class="max-w-7xl mx-auto flex flex-col items-center justify-center gap-4 px-4 py-4 md:flex-row md:items-center md:justify-between md:px-8 md:py-4 xl:px-10 xl:py-4">
      <!-- Texto de apoyo solo visible en tablet y desktop -->
      <div class="hidden min-w-0 md:flex md:flex-col md:gap-1">
        <h3 class="m-0 text-[var(--Schemes-On-Primary,#FFF)] font-lato text-sm font-bold leading-[20px] tracking-[0.25px]">
          Agenda tu demo con un especialista
        </h3>
        <p class="m-0 text-[var(--Palettes-Neutral-80,#D0C4C4)] font-lato text-sm leading-[20px] tracking-[0.25px]">
          Recibe orientación personalizada sin compromiso.
        </p>
      </div>
      
      <!-- Botón siempre visible -->
      <a id="btnWhatsapp" href="https://wa.me/525559854347" target="_blank" rel="noopener noreferrer"
         class="medrent-btn-primary w-full shrink-0 whitespace-nowrap md:w-auto">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">

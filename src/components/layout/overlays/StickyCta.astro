        Agenda tu DEMO
      </a>
    </div>
</div>
)}


<style>
#btnWhatsapp {
  box-sizing: border-box;
}

#BtnWhatsappDemo {
  box-sizing: border-box;
  /* Solo safe area bajo la barra; sin espacio “blanco” debajo del bloque */
  padding-bottom: env(safe-area-inset-bottom, 0px);
}
</style>
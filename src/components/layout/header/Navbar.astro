      <!-- Botón cerrar -->
      <button @click="open = false" class="bg-white rounded-[4px] p-1">
        <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
      
    <!-- Enlaces -->
    <div class="flex-1 px-4 py-6 flex flex-col gap-6 overflow-auto" id="mobileMenuLinks">
      <div class="bg-white rounded-lg">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between">
          <div class="mb-4 md:mb-0">
            <div class="font-bold text-base leading-6 tracking-[0.5px]" style="font-weight: 700;">
              Hablemos de innovación médica
            </div>
            <div class="font-normal text-base leading-6 tracking-[0.5px]" style="font-weight: 200; font-size: 13px;">
              Estamos listos para asesorarte en equipo de alta especialidad.
            </div>
          </div>
          <a href="/contacto" class="w-full md:w-auto bg-[var(--color-primary)] text-white text-center px-4 py-2 rounded font-semibold">
            Contáctanos
          </a>
        </div>
      </div>

      <!-- MARCAS MOBILE -->
      <div x-data="{ marcasMobileOpen: false }">
        <a @click="marcasMobileOpen = !marcasMobileOpen" :class="marcasMobileOpen ? 'py-6 border-b border-[var(--color-primary)] flex items-center justify-between cursor-pointer text-[var(--color-primary)]' : 'py-6 border-b border-[var(--color-gray-dark)] flex items-center justify-between cursor-pointer text-[#261819]'">
          <span>Nuestras marcas</span>
          <svg class="w-4 h-4 ml-2" :class="{ 'rotate-180': marcasMobileOpen }" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </a>
        <div x-show="marcasMobileOpen" x-transition class="flex flex-wrap gap-4 w-full" >
          <div class="grid grid-cols-1 gap-4 w-full pt-4">
           {marcasNavData.length > 0 ? (
                marcasNavData.map((marca) => (
                  <a 
                    href={`/nuestras-marcas/${marca.slug}`}
                    class="marcaLink flex items-center justify-between gap-2 text-gray-700 transition-colors p-4"
                  >
                    <span class="marcaName transition-colors">
                      {marca.name}
                    </span>
                    <svg 
                      xmlns="http://www.w3.org/2000/svg" 
                      width="24" height="23" viewBox="0 0 24 23" fill="none" 
                      class="marcaIcon transition-colors"
                    >
                      <path d="M17.9199 6.34417C17.8185 6.11 17.6243 5.92391 17.3799 5.82667C17.2597 5.77756 17.1306 5.75151 16.9999 5.75H6.99994C6.73472 5.75 6.48037 5.85097 6.29283 6.03069C6.1053 6.21041 5.99994 6.45417 5.99994 6.70833C5.99994 6.9625 6.1053 7.20625 6.29283 7.38598C6.48037 7.5657 6.73472 7.66667 6.99994 7.66667H14.5899L6.28994 15.6112C6.19621 15.7003 6.12182 15.8063 6.07105 15.9231C6.02028 16.0399 5.99414 16.1652 5.99414 16.2917C5.99414 16.4182 6.02028 16.5434 6.07105 16.6602C6.12182 16.777 6.19621 16.883 6.28994 16.9721C6.3829 17.0619 6.4935 17.1332 6.61536 17.1819C6.73722 17.2305 6.86793 17.2556 6.99994 17.2556C7.13195 17.2556 7.26266 17.2305 7.38452 17.1819C7.50638 17.1332 7.61698 17.0619 7.70994 16.9721L15.9999 9.01792V16.2917C15.9999 16.5458 16.1053 16.7896 16.2928 16.9693C16.4804 17.149 16.7347 17.25 16.9999 17.25C17.2652 17.25 17.5195 17.149 17.707 16.9693C17.8946 16.7896 17.9999 16.5458 17.9999 16.2917V6.70833C17.9984 6.5831 17.9712 6.45938 17.9199 6.34417Z" fill="currentColor"></path>
                    </svg>
                  </a>

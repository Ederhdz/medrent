---
const {
  items,
  textColor,
  /** 'dark' = barra negra (PLP/PDP). 'light' = hero claro sin fondo. */
  surface = 'dark',
  /** 'overlay' = nav absolute (comportamiento anterior). 'inline' = flujo normal, útil en hero. */
  navPosition = 'overlay',
} = Astro.props as {
  items: { name: string; href?: string }[];
  textColor?: string;
  surface?: 'dark' | 'light';
  navPosition?: 'overlay' | 'inline';
};
const outerBg = surface === 'light' ? 'bg-transparent' : 'bg-[#000]';
const navLayout =
  navPosition === 'inline'
    ? 'relative'
    : 'absolute';
---
<div class={`mx-auto flex w-full max-w-[1280px] flex-col justify-start ${outerBg}`}>
  <nav
    class={`mx-auto flex w-full max-w-[1280px] items-center px-8 py-2 font-lato ${navLayout}`}
    aria-label="Breadcrumb"
  >
    <ol class="scrollbar-hide flex touch-pan-x items-center gap-2 overflow-x-auto whitespace-nowrap text-[12px] uppercase leading-4 tracking-[0.08em]">
      {items.map((item, index) => {
        const isLast = index === items.length - 1;

        return (
          <>
            <li>
              {isLast ? (
                <span class={`font-semibold ${textColor || 'text-black'}`}>
                  {item.name}
                </span>
              ) : (
                <a
                  href={item.href}
                  class={`opacity-70 hover:opacity-100 transition cursor-pointer ${textColor || 'text-black'}`}
                  style="cursor: pointer;"
                >
                  {item.name}
                </a>
              )}
            </li>

            {!isLast && (
              <li class={`${index === items.length - 2 ? '' : 'opacity-70'} shrink-0`} aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M10 7L15 12L10 17L10 7Z" fill={textColor === 'text-white' ? 'white' : 'black'}/>
                </svg>
              </li>
            )}
          </>
        );
      })}
    </ol>
  </nav>
</div>

<style>
  /* Ocultar scrollbar pero mantener funcionalidad */
  .scrollbar-hide {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;  /* Chrome, Safari and Opera */
  }
</style>
---
const baseUrl = Astro.site; // Uses the same value as Layout canonical
const organizationId = `${baseUrl}/#organization`;

// Keep this global schema "stable": templates can add WebPage/BreadcrumbList specifics.
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "MedicalOrganization",
  "@id": organizationId,
  "name": "MedRent",
  "legalName": "Med Rent S.A. de C.V.",
  "url": `${baseUrl}/`,
  "logo": {
    "@type": "ImageObject",
    "@id": `${baseUrl}/#logo`,
    "url": `${baseUrl}/wp-content/uploads/2023/07/MedRent-Logo.jpg`,
    "width": 672,
    "height": 316,
    "caption": "MedRent - Tecnología Médica de Alta Especialidad",
  },
  "description":
    "Distribuidor líder de tecnología médica de alta especialidad en Neurofisiología, Neurocirugía, Neuromodulación, Rehabilitación y Neurovascular.",
  "foundingDate": "2009-01-01",
  "areaServed": {
    "@type": "Country",
    "name": "Mexico",
    "identifier": "MX",
  },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Av. Insurgentes Sur 866, Del Valle, Benito Juárez",
    "addressLocality": "Ciudad de México",
    "addressRegion": "CDMX",
    "postalCode": "03100",
    "addressCountry": "MX",
  },
  "contactPoint": [
    {
      "@type": "ContactPoint",
      "telephone": "+52-55-5985-4347",
      "email": "info@medrent.mx",
      "contactType": "customer service",
      "areaServed": "MX",
      "availableLanguage": ["es"],
    },
    {
      "@type": "ContactPoint",
      "telephone": "+52-55-6952-6686",
      "contactType": "sales",
      "areaServed": "MX",
      "availableLanguage": ["es"],
    },
  ],
  "medicalSpecialty": [
    {
      "@type": "MedicalSpecialty",
      "name": "Neurophysiology",
      "alternateName": "Neurofisiología",
      "url": `${baseUrl}/especialidades/neurofisiologia`,
    },
    {
      "@type": "MedicalSpecialty",
      "name": "Neurosurgery",
      "alternateName": "Neurocirugía",
      "url": `${baseUrl}/especialidades/neurocirugia`,
    },
    {
      "@type": "MedicalSpecialty",
      "name": "Neuromodulation",
      "alternateName": "Neuromodulación",
      "url": `${baseUrl}/especialidades/neuromodulacion`,
    },
    {
      "@type": "MedicalSpecialty",
      "name": "Physical and Rehabilitation Medicine",
      "alternateName": "Rehabilitación",
      "url": `${baseUrl}/especialidades/rehabilitacion`,
    },
    {
      "@type": "MedicalSpecialty",
      "name": "Neurovascular",
      "alternateName": "Neurovascular",
      "url": `${baseUrl}/especialidades/neurovascular`,
    },
  ],
  "knowsAbout": [
    "Electroencefalografía (EEG)",
    "Electromiografía (EMG)",
    "Monitoreo Neurofisiológico Intraoperatorio (IONM)",
    "Neuronavegación",
    "Doppler transcraneal (TCD)",
    "Neuromodulación (VNS, tVNS, TMS)",
    "Rehabilitación neurológica y fisioterapia",
  ],
};
---
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
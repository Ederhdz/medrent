---
interface Props {
  title?: string;
  seoTitle?: string;
  seoDescription?: string;
  /** Si se pasa junto con `title`, muestra el bloque de encabezado al estilo PLP productos */
  productCount?: number;
}
import Newsletter from '@components/FormNewsletter.astro';
import PromotionSlider from '@components/sections/PromotionSlider.astro';
import { getPromotionSlides } from "@server/api/promotions";

const promotionsData = await getPromotionSlides();
const { title, productCount } = Astro.props;
const showHeading = Boolean(title);
const plpGradient =
  "bg-[linear-gradient(266deg,#007BB6_0%,#00827F_100.77%)] bg-clip-text text-transparent";
---

<section class="max-w-7xl mx-auto px-4 pt-6 pb-12">
  <slot name="top" />

  {showHeading && (
    <div class="mb-8 flex flex-col">
      <h1
        class={`plp-heading-title font-lato self-stretch font-bold text-[32px] leading-[40px] md:text-[28px] md:leading-[36px] md:filter-none ${plpGradient}`}
      >
        {title}
      </h1>
      {typeof productCount === "number" && (
        <p class={`mt-1 font-lato text-[22px] font-normal leading-[28px] ${plpGradient}`}>
          {productCount} {productCount === 1 ? "Equipo disponible" : "Equipos disponibles"}
        </p>
      )}
    </div>
  )}

  <div class="flex flex-col lg:flex-row lg:items-start lg:min-h-0 gap-8">
    <!-- SIDEBAR -->
    <aside class="plp-filters-scroll lg:w-64 w-full">
      <slot name="filters" />
    </aside>

    <!-- CONTENT -->
    <div class="flex-1">
      <slot />
    </div>
  </div>
</section>

<!-- Slider de promociones -->
<PromotionSlider promotionsData={promotionsData} />

<!-- Newsletter -->
<Newsletter />

<style>
  body { background-color: var(--color-secondary-light); }
  .heroproductos nav { position: absolute !important; }

  /* headline/large en mobile: sombra sobre texto con gradiente (drop-shadow respeta el alpha) */
  @media (max-width: 767px) {
    .plp-heading-title {
      filter: drop-shadow(0 8px 10px rgba(49, 48, 48, 0.04))
        drop-shadow(0 20px 24px rgba(49, 48, 48, 0.1));
    }
  }

  .plp-filters-scroll {
    scroll-padding-bottom: 24px;
  }

  @media (min-width: 1024px) {
    .plp-filters-scroll {
      --plp-sticky-top: 116px;
      --plp-sticky-bottom-safe: 140px;
      position: sticky;
      top: var(--plp-sticky-top);
      align-self: flex-start;
      min-height: 0;
      height: auto;
      max-height: calc(100vh - var(--plp-sticky-top) - var(--plp-sticky-bottom-safe));
      max-height: calc(100dvh - var(--plp-sticky-top) - var(--plp-sticky-bottom-safe));
      overflow-y: auto;
      overscroll-behavior: contain;
      padding-right: 8px;
      padding-bottom: 8px;
    }
  }

  .plp-filters-scroll::-webkit-scrollbar {
    width: 8px;
  }

  .plp-filters-scroll::-webkit-scrollbar-thumb {
    background: var(--color-primary);
    border-radius: 999px;
  }

  .plp-filters-scroll::-webkit-scrollbar-track {
    background: rgba(0, 103, 100, 0.18);
    border-radius: 999px;
  }

  .plp-filters-scroll {
    scrollbar-width: thin;
    scrollbar-color: var(--color-primary) rgba(0, 103, 100, 0.18);
  }
</style>
---
const { data, archivoPDF } = Astro.props;
---

<!-- Ficha Técnica -->
{data && data.length > 0 && (
    <section id="DesktopFichaTecnica" class="hidden md:block max-w-7xl mx-auto py-8">
        <p class="text-[var(--color-primary)]  text-[14px] font-medium m-0">
            FICHA TÉCNICA
        </p>
        <div class="flex justify-between items-center mb-8">
            <h2 class="text-[24px] md:text-[28px] font-bold text-[#212121] ">
                Características de producto
            </h2>
            {archivoPDF && (
                <a
                    href={archivoPDF}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="border-2 border-[var(--color-primary)] text-[var(--color-primary)] font-bold rounded transition-colors flex items-center gap-2 cursor-pointer group px-4 py-2 hover:bg-[var(--color-primary)] hover:text-white"
                    style="border-radius: 4px;"
                    download
                >
                    Descargar ficha técnica
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                        <path d="M17.174 4H13V0H5.00005V4H0.82605L9.00005 13.537L17.174 4ZM7.00005 6V2H11V6H12.826L9.00005 10.463L5.17405 6H7.00005Z" fill="currentColor" class="group-hover:fill-white"/>
                        <path d="M16 12V16H2V12H0V18H18V12H16Z" fill="currentColor" class="group-hover:fill-white"/>
                    </svg>
                </a>
            )}
        </div>
    
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {data.map((category: any, index: number) => (
                <div class={`bg-white overflow-hidden ${data.length === 1 ? 'w-full col-span-2' : ''}`} style="border-radius: 16px; border: 1px solid #EDF2F0;">

                    <!-- Título de la categoría -->
                    <div class="px-6 py-4">
                        <h3 class="text-black  text-[14px] uppercase font-bold">
                            {category.groupTitle}
                        </h3>
                    </div>
                    
                    <!-- Tabla de características -->
                    {category.technicalFeature && category.technicalFeature.length > 0 && (
                        <div class="overflow-x-auto">
                            <table class="w-full">
                                <tbody>
                                    {category.technicalFeature.map((feature: any, idx: number) => (
                                    <tr class={idx % 2 === 0 ? 'bg-[#EDF2F0]' : 'bg-white'}>
                                        <td class="px-6 py-4 text-[var(--color-text-default)] font-medium text-sm w-1/2">
                                            {feature.feature}:
                                        </td>
                                        <td class="px-6 py-4 text-[var(--color-text-default)] text-sm w-1/2">
                                            {feature.description}
                                        </td>
                                    </tr>
                                    ))}
                                </tbody>
                            </table>
                        </div>
                    )}
                </div>
            ))}
        </div>
    </section>
)}



<script is:inline>
    const btnMas = document.getElementById('ver-mas-btn');
    const btnMenos = document.getElementById('ver-menos-btn');
    const extra = document.getElementById('ficha-categorys-extra');
    const cardOpacidad = document.getElementById('card-opacidad');
    let expanded = false;
    function expandExtra() {
        extra.style.maxHeight = extra.scrollHeight + 'px';
        btnMas.classList.add('hidden');
        btnMenos.classList.remove('hidden');
        if(cardOpacidad && window.innerWidth < 768) cardOpacidad.classList.remove('opacity-40');
        expanded = true;
    }
    function collapseExtra() {
        extra.style.maxHeight = '0px';
        btnMas.classList.remove('hidden');
        btnMenos.classList.add('hidden');
        if(cardOpacidad && window.innerWidth < 768) cardOpacidad.classList.add('opacity-40');
        expanded = false;
    }
    btnMas?.addEventListener('click', expandExtra);
    btnMenos?.addEventListener('click', collapseExtra);
    // Si cambia el tamaño de pantalla, colapsa en desktop
    window.addEventListener('resize', () => {
        if (window.innerWidth >= 768 && expanded) {
            collapseExtra();
        }
    });
    // Inicializa opacidad solo en mobile si corresponde
    if(cardOpacidad && btnMas && window.innerWidth < 768) {
        cardOpacidad.classList.add('opacity-40');
    } else if(cardOpacidad) {
        cardOpacidad.classList.remove('opacity-40');
    }
</script>
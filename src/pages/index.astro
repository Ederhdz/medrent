                    <BlocksRenderer content={dataHome.DescripcionContacto} />
                ) : (
                    <>
                        <span class="font-light">En MedRent no solo distribuimos equipos, impulsamos tu crecimiento profesional. Déjanos asesorarte para encontrar la solución tecnológica perfecta para transformar la vida de tus pacientes.</strong>
                    </>

                id="home-form"
                class="space-y-6 "
                >
                <FormField
                    label="Nombre completo"
                    name="name"
                    placeholder="Ej: Dra. Carolina Ávila"
                />

                <FormField
                    label="Correo electrónico"
                    name="email"
                    type="email"
                    placeholder="Ej: carolina.avila@hospitalneuro.mx"
                />
                
                <PhoneField />

                <SelectField
                    label="Especialidad médica"
                    name="specialty"
                    options={[
                        "Neurocirugía",
                        "Neurofisiología",
                        "Neuromodulación",
                        "Rehabilitación",
                        "Neurovascular",
                        "Otra"

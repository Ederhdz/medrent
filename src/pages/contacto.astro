---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import { SITE } from '@lib/site';
const site = SITE;
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import Breadcrumb from '@components/navigation/Breadcrumb.astro';

import BaseForm from "@components/forms/BaseForm.astro";
import FormField from "@components/forms/FormField.astro";
import PhoneField from "@components/forms/PhoneField.astro";
import SelectField from "@components/forms/SelectField.astro";
import SubmitButton from "@components/forms/SubmitButton.astro";
import CheckboxField from "@components/forms/CheckboxField.astro";

---


<Layout title="Med Rent - Contacto">
    <Fragment slot="head">
        <BreadcrumbSchema
        items={[
            { name: 'Inicio', url: 'https://www.medrent.mx' },
            { name: 'Contacto', url: 'https://www.medrent.mx/contacto' },
        ]}
        />
    </Fragment>

    <Breadcrumb
        textColor="text-black"
        items={[
            { name: "INICIO", href: "/" },
            { name: "CONTACTO" }
        ]}
    />
    
    <section class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 items-start relative z-10">
        
        <!-- Columna 1: Encabezado -->
        <div class="p-4 md:p-6 lg:pt-20 lg:pr-[103px] lg:pb-6 lg:pl-[135px]">
            <h3 class="text-[#00827F] font-700 text-[14px] md:text-[14px] uppercase mt-8">
                Contacto
            </h3>
            <h2 class="font-normal md:text-[28px] text-[28px]">
                Agenda una DEMO con nuestro equipo técnico y nuestros especialistas de producto.
            </h2>
            <p
                class="text-[#212121] md:text-[16px] text-[16px] text-[#5A4043] mt-2 text-pretty"
            >
                <span class="font-light">
                    En <b>Medrent</b> estamos listos para ayudarte con atención
                    personalizada y soluciones médicas a la medida de tu práctica.
                </span>
            </p>
        </div>

        <!-- Columna 2: Formulario -->
        <div class="p-4 md:p-6 lg:pt-20 lg:pr-[134px] lg:pb-6 lg:pl-[115px]">
            <!-- Columna 2: Formulario -->
            <BaseForm id="contact-form" class="space-y-6 bg-white rounded">
                <FormField
                    label="Nombre completo"
                    name="name"
                    placeholder="Ej: Dra. Carolina Ávila"
                />
                <FormField
                    label="Correo electrónico"
                    name="email"
                    type="email"
                    placeholder="Ej: carolina.avila@neuro.mx"
                />
                <PhoneField
                    label="Teléfono de contacto"
                    name="phone"
                    placeholder="Ej: 55 1234 5678"
                />


                <!-- Institución o clínica -->
                <div class="relative">
                    <label
                        class="absolute -top-3 left-3 bg-[var(--color-green-dark)] px-2 text-sm text-[#FFF] rounded-xs"
                        >Nombre de institución o clínica*</label
                    >
                    <input
                        name="lugar_de_trabajo"
                        type="text"
                        placeholder="Ej: Clínica Neuro"
                        required
                        class="phone-input w-full border-[var(--color-green-dark)] border-2 rounded-[4px] px-4 py-3 placeholder:text-[#A0A0A0] text-[var(--color-green-dark)] focus:outline-none bg-white hover:bg-[var(--color-secondary-light)] focus:bg-[var(--color-secondary-light)] transition-colors duration-300"
                    />
                </div>
                
                <SelectField
                    label="Especialidad médica"
                    name="specialty"
                    options={["Neurocirugía", "Neurofisiología", "Neuromodulación", "Rehabilitación", "Neurovascular", "Otra"]}
                />    

                <!-- Estado de la República -->
                <div class="relative">
                    <label
                        class="absolute -top-3 left-3 bg-[var(--color-green-dark)] px-2 text-sm text-[#FFF] rounded-xs"
                        >Estado de la república*</label
                    >
                    
                    <!-- Botón que abre el dropdown -->
                    <button
                        type="button"
                        id="estado-btn"
                        class="w-full border-2 border-[var(--color-green-dark)] rounded-[4px] px-4 py-3 text-left text-[#A0A0A0] bg-white hover:bg-[var(--color-secondary-light)] focus:bg-[var(--color-secondary-light)] transition-colors duration-300 flex justify-between items-center"
                        style="overscroll-behavior: contain;"
                    >
                        <span id="estado-seleccionado">Selecciona tu estado</span>
                        <svg class="w-4 h-4 text-[#5A3A36]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                        </svg>
                    </button>

                    <!-- Dropdown oculto con scroll -->
                    <div 
                        id="estado-dropdown" 
                        class="absolute left-0 w-full hidden z-[10000]" 
                        style="top:100%;"
                    >
                        <div class="border-2 border-[var(--color-green-dark)] border-t-0 rounded-b-[4px] bg-white shadow-lg max-h-[170px] overflow-y-auto" style="overscroll-behavior: contain;">
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Aguascalientes">Aguascalientes</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Baja California">Baja California</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Baja California Sur">Baja California Sur</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Campeche">Campeche</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Chiapas">Chiapas</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Chihuahua">Chihuahua</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Ciudad de México">Ciudad de México</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Coahuila">Coahuila</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Colima">Colima</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Durango">Durango</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Estado de México">Estado de México</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Guanajuato">Guanajuato</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Guerrero">Guerrero</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Hidalgo">Hidalgo</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Jalisco">Jalisco</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Michoacán">Michoacán</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Morelos">Morelos</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Nayarit">Nayarit</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Nuevo León">Nuevo León</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Oaxaca">Oaxaca</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Puebla">Puebla</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Querétaro">Querétaro</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Quintana Roo">Quintana Roo</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="San Luis Potosí">San Luis Potosí</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Sinaloa">Sinaloa</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Sonora">Sonora</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Tabasco">Tabasco</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Tamaulipas">Tamaulipas</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Tlaxcala">Tlaxcala</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Veracruz">Veracruz</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Yucatán">Yucatán</div>
                            <div class="estado-option px-4 py-2 hover:bg-[var(--color-secondary-light)] hover:text-[var(--color-primary)] cursor-pointer" data-value="Zacatecas">Zacatecas</div>
                        </div>
                    </div>
                    
                    <!-- Input oculto para enviar el valor -->
                    <input type="hidden" name="estado_mx" id="estado_mx_input" value="" required />
                </div>

                <!-- ¿Cómo nos conociste? -->
                <div class="relative">
                    <label
                        class="absolute -top-3 left-3  bg-[var(--color-green-dark)]  px-2 text-sm text-[#FFF] rounded-xs"
                        >¿Por qué medio nos conociste?*</label
                    >
                    <input
                        name="por_qu_medio_nos_conociste"
                        type="text"
                        placeholder="Ej: Congreso, recomendación, redes..."
                        required
                        class="w-full border border-[var(--color-green-dark)]  px-4 py-3 rounded placeholder:text-[#A0A0A0] text-[#212121] focus:outline-none focus:ring-0 hover:bg-[var(--color-secondary-light)] focus:bg-[var(--color-secondary-light)] transition-colors duration-300"
                    />
                </div>

                <!-- Mensaje -->
                <div class="relative">
                    <label
                        class="absolute -top-3 left-3  bg-[var(--color-green-dark)]  px-2 text-sm text-[#FFF] rounded-xs"
                        >Mensaje</label
                    >
                    <textarea
                        name="message"
                        id="message"
                        rows="4"
                        placeholder="Cuéntanos tus dudas o necesidades..."
                        class="w-full border border-[var(--color-green-dark)]  px-4 py-3 rounded placeholder:text-[#A0A0A0] text-[#212121] focus:outline-none focus:ring-0"
                    ></textarea>
                </div>


                <!-- Checkbox -->
                <CheckboxField
                    id="aviso"
                    label="He leído y acepto el"
                    link="/aviso-de-privacidad"
                />

                <!-- Botón -->
                <SubmitButton text="Recibir asesoría personalizada"></SubmitButton>
                
                <div id="status" class="text-center mt-2 text-sm"></div>
            </BaseForm>
        </div>
        <script type="module">
            import { initForm } from "/scripts/formValidator.js";

            document.addEventListener("DOMContentLoaded", () => {
                initForm("contact-form");
            });
        </script>
    </section>

    <!--  FOOTER CONTACTO -->
    <section class="w-full  " >
        <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-8 items-start rounded-t-[32px] p-8" style="background: linear-gradient(rgba(105,216,211,0.08), rgba(105,216,211,0.08)), #0F1414">
            <!-- INFORMACIÓN -->
            <div class="space-y-6">
                <h3 class="uppercase text-[#87F4EF] font-Lato text-[28px] font-700 tracking-wide">Información de contacto</h3>
                <div>
                    <p class="font-semibold text-white">Teléfono</p>
                    <a href="https://wa.me/{site.contact}" target="_blank" rel="noopener noreferrer" class="text-[#87F4EF] underline">
                        {site.contactText}
                    </a>
                </div>

                <div>
                    <p class="font-semibold text-white">Correo</p>
                    <a href="mailto:{site.email}" class="text-[#87F4EF]">
                        {site.email}
                    </a>
                </div>

                <div>
                    <p class="font-semibold text-white">Horario de atención</p>
                    <p class=" text-[#FFFF]">Lunes a Viernes, 9:00 a.m. – 6:00 p.m. (Hora de México)</p>
                </div>

                <div>
                    <p class="font-semibold text-white">Dirección</p>
                    <p class=" text-[#87F4EF]">Av. Insurgentes Sur 866, Del Valle, Benito Juárez, 03100 Ciudad de México, CDMX.</p>
                </div>

                <a href="https://maps.google.com/?q=Insurgentes+Sur+866,+Del+Valle,+Benito+Juárez,+03100+Ciudad+de+México,+CDMX" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 border border-white text-white px-4 py-2 rounded bg-[#FFFF]">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M15 4.94606L9 2.94606L2 5.27906V21.3881L9 19.0541L15 21.0541L22 18.7211V2.61206L15 4.94606ZM10 5.38706L14 6.72006V18.6131L10 17.2801V5.38706ZM4 6.72106L8 5.38706V17.2791L4 18.6121V6.72106ZM20 17.2791L16 18.6131V6.72106L20 5.38806V17.2791Z" fill="var(--color-primary)"/>
                    </svg>              
                    <span class="text-sm font-medium text-[var(--color-primary)]">Cómo llegar</span>
                </a>
            </div>
            
            <!-- MAPA -->
            <div class="overflow-hidden rounded-[32px]">
                <iframe
                    class="w-full h-96 rounded-[32px] border-0"
                    loading="lazy"
                    allowfullscreen
                    referrerpolicy="no-referrer-when-downgrade"
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3763.5752062788406!2d-99.17664532314329!3d19.38753774211532!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85d1ff768ec55555%3A0xad7538bfcf6a0471!2sMedRent!5e0!3m2!1ses-419!2smx!4v1770915146839!5m2!1ses-419!2smx">
                </iframe>
            </div>
        </div>
    </section>
</Layout>



<!-- SCROLL EN INPUT ESTADOS DE LA REPÚBLICA -->
<script>
    const estadoBtn = document.getElementById('estado-btn');
    const estadoDropdown = document.getElementById('estado-dropdown');
    const estadoSeleccionado = document.getElementById('estado-seleccionado');
    const estadoInput = document.getElementById('estado_mx_input');
    const scrollableDiv = estadoDropdown?.querySelector('.overflow-y-auto');
    
    // Abrir/cerrar dropdown
    estadoBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        estadoDropdown.classList.toggle('hidden');
    });
    
    // Manejar scroll dentro del dropdown (para Lenis)
    if (scrollableDiv) {
        scrollableDiv.addEventListener('wheel', (e) => {
            e.stopPropagation();
            scrollableDiv.scrollTop += e.deltaY;
        });
    }
    
    // Seleccionar opción
    document.querySelectorAll('.estado-option').forEach(option => {
        option.addEventListener('click', () => {
            const value = option.dataset.value;
            estadoSeleccionado.textContent = value;
            estadoInput.value = value;
            estadoDropdown.classList.add('hidden');
            
            // Disparar evento change para validación
            estadoInput.dispatchEvent(new Event('change'));
            
            // Aplicar estilo de validación
            if (estadoInput.value !== '') {
                estadoBtn.classList.add('bg-[var(--color-secondary-light)]');
            }
        });
    });
    
    // Cerrar dropdown al hacer click fuera
    document.addEventListener('click', (e) => {
        if (!estadoBtn.contains(e.target) && !estadoDropdown.contains(e.target)) {
            estadoDropdown.classList.add('hidden');
        }
    });
</script>
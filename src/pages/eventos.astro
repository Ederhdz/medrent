        // CALENDARIO
        
        function generarCalendario(fechaBase) {
            const fecha = dayjs(fechaBase);
            const startOfMonth = fecha.startOf('month');
            const startOfWeek = startOfMonth.startOf('week');
            
            const calendarDays = [];
            let currentDay = startOfWeek;
            
            for (let i = 0; i < 42; i++) {
                calendarDays.push({
                    day: currentDay.date(),
                    isCurrentMonth: currentDay.month() === fecha.month(),
                    isToday: currentDay.isSame(dayjs(), 'day'),
                    fullDate: currentDay.format('YYYY-MM-DD')
                });
                currentDay = currentDay.add(1, 'day');
            }
            
            return {
                dias: calendarDays,
                nombreMes: (() => {
                    const raw = fecha.format('MMMM YYYY');
                    return raw.charAt(0).toUpperCase() + raw.slice(1).toLowerCase();
                })()
            };
        }
        
        function actualizarCalendario(mesKey) {
            const calendario = generarCalendario(mesKey + '-01');
            const mesActualElement = document.getElementById('mes-actual');
            const calendarioDiasContainer = document.querySelector('#calendario-dinamico .grid.grid-cols-7.gap-1');
            
            const seccionMes = document.querySelector(`[data-month="${mesKey}"]`);
            let diasConEventos = [];
            
            if (seccionMes) {
                const eventDaysAttr = seccionMes.getAttribute('data-event-days');
                if (eventDaysAttr) {
                    try { diasConEventos = JSON.parse(eventDaysAttr); } catch (e) {}
                }
            }
            
            if (mesActualElement) mesActualElement.textContent = calendario.nombreMes;
            
            if (calendarioDiasContainer) {
                calendarioDiasContainer.innerHTML = calendario.dias.map(dayInfo => {
                    const hasEvent = dayInfo.isCurrentMonth && diasConEventos.includes(dayInfo.day);
                    const clases = `flex justify-center items-center w-10 h-10 rounded-full text-sm font-medium mx-auto ${
                        dayInfo.isToday ? "border-3 border-[#006764] bg-transparent" :
                        hasEvent ? "bg-[#006764] text-white" :
                        dayInfo.isCurrentMonth ? "text-gray-700 hover:bg-gray-100 cursor-pointer" : "text-gray-300"
                    }`;
                    return `<div class="${clases}">${dayInfo.day}</div>`;
                }).join('');
            }
        }
        
        function configurarObserver() {
            const secciones = document.querySelectorAll('[data-month]');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting && entry.intersectionRatio > 0.5) {
                        const mesKey = entry.target.getAttribute('data-month');
                        if (mesKey) actualizarCalendario(mesKey);
                    }
                });
            }, { threshold: [0.5], rootMargin: '-120px 0px -50% 0px' });
            
            secciones.forEach(seccion => observer.observe(seccion));
        }
        
        // Inicializar calendario
        configurarObserver();
        let mesInicial = dayjs().format('YYYY-MM');
        const primerSeccionMes = document.querySelector('[data-month]');
        if (primerSeccionMes) {
            const mesKey = primerSeccionMes.getAttribute('data-month');
            if (mesKey) mesInicial = mesKey;
        }
        actualizarCalendario(mesInicial);
    });

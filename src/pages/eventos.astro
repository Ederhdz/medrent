                e.preventDefault();
                openEventPopup({
                    img: this.getAttribute('data-img') || '',
                    title: this.getAttribute('data-title') || 'Evento MedRent',
                    description: this.getAttribute('data-description') || 'Descripción del evento'
                });
            });
        });
        
        // Cerrar popup
        if (closePopupBtn) closePopupBtn.addEventListener('click', closeEventPopup);
        if (popupOverlay) {
            popupOverlay.addEventListener('click', (e) => {
                if (e.target === popupOverlay) closeEventPopup();
            });
        }
        
        // Tecla Escape
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && popupOverlay && !popupOverlay.classList.contains('hidden')) {

                                                                />
                                                            </div>
                                                            <div class="w-full md:w-1/2 p-6 flex flex-col bg-[#F5FAF9]">
                                                                <div class="flex-1">
                                                                    <p class="text-[var(--color-accent)] font-lato text-[14px] uppercase font-medium mb-2">
                                                                        {evento.eventType}
                                                                    </p>
                                                                    <h3 class="text-[#261819] font-lato text-[20px] font-bold mb-1">
                                                                        {evento.title}
                                                                    </h3>
                                                                    {/* <p class="text-[#261819] font-lato text-[20px] mb-4">
                                                                        {evento.subtitle}
                                                                    </p> */}
                                                                    <div class="space-y-2">
                                                                        <div class="flex items-center gap-2">
                                                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" class="flex-shrink-0">
                                                                            <path d="M12 21C11.656 21 11.336 20.823 11.153 20.532L7.19501 14.227C6.98901 13.9 6.79201 13.565 6.61601 13.222C5.34901 10.739 4.01501 7.08802 7.04801 4.05302C8.35801 2.74202 10.116 2.02002 12 2.02002C13.883 2.02002 15.642 2.74202 16.952 4.05202C20.002 7.10402 18.638 10.788 17.347 13.293C17.195 13.589 17.024 13.879 16.847 14.162L12.847 20.532C12.664 20.823 12.344 21 12 21ZM12 4.02002C10.65 4.02002 9.39401 4.53302 8.46201 5.46602C6.81101 7.11902 6.79101 9.16702 8.39701 12.312C8.54501 12.603 8.71401 12.886 8.88801 13.163L12 18.12L15.152 13.099C15.298 12.865 15.442 12.624 15.568 12.377C17.209 9.19502 17.199 7.12802 15.538 5.46602C14.605 4.53302 13.35 4.02002 12 4.02002Z" fill="#3D4948"/>
                                                                            <path d="M12 12C10.346 12 9 10.654 9 9C9 7.346 10.346 6 12 6C13.654 6 15 7.346 15 9C15 10.654 13.654 12 12 12ZM12 8C11.449 8 11 8.449 11 9C11 9.551 11.449 10 12 10C12.551 10 13 9.551 13 9C13 8.449 12.551 8 12 8Z" fill="#3D4948"/>
                                                                            <path d="M17 19H7V21H17V19Z" fill="#3D4948"/>
                                                                        </svg>
                                                                        <span class="text-[#261819] text-[16px]">
                                                                            <a href={evento.locationUrlMaps} target="_blank" class="hover:text-[var(--color-accent)] transition-colors">
                                                                                {evento.locationLabel}
                                                                            </a>
                                                                        </span>
                                                                    </div>
                                                                        <div class="flex items-center gap-2">
                                                                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                                                                <path d="M17 4V2H15V4H9V2H7V4H3V21H21V4H17ZM7 6V8H9V6H15V8H17V6H19V10H5V6H7ZM5 19V12H19V19H5Z" fill="#3D4948"/>
                                                                            </svg>
                                                                            <span class="text-[#261819] text-[16px]">{fechaTexto}</span>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="pt-4">
                                                                    <button 
                                                                        class="event-popup-btn inline-flex items-center gap-2 text-[#006764] font-lato text-[14px] hover:opacity-80 transition-opacity bg-transparent border-none cursor-pointer"
                                                                        data-title={evento.title || ''}
                                                                        data-description={evento.subtitle || ''}
                                                                        data-img={evento.image?.url || ''} 
                                                                    >
                                                                        Saber más
                                                                       <svg xmlns="http://www.w3.org/2000/svg" width="24" height="23" viewBox="0 0 24 23" fill="none">
                                                                            <path d="M17.92 6.34417C17.8185 6.11 17.6243 5.92391 17.38 5.82667C17.2598 5.77756 17.1307 5.75151 17 5.75H7C6.73478 5.75 6.48043 5.85097 6.29289 6.03069C6.10536 6.21041 6 6.45417 6 6.70833C6 6.9625 6.10536 7.20625 6.29289 7.38598C6.48043 7.5657 6.73478 7.66667 7 7.66667H14.59L6.29 15.6112C6.19627 15.7003 6.12188 15.8063 6.07111 15.9231C6.02034 16.0399 5.9942 16.1652 5.9942 16.2917C5.9942 16.4182 6.02034 16.5434 6.07111 16.6602C6.12188 16.777 6.19627 16.883 6.29 16.9721C6.38296 17.0619 6.49356 17.1332 6.61542 17.1819C6.73728 17.2305 6.86799 17.2556 7 17.2556C7.13201 17.2556 7.26272 17.2305 7.38458 17.1819C7.50644 17.1332 7.61704 17.0619 7.71 16.9721L16 9.01792V16.2917C16 16.5458 16.1054 16.7896 16.2929 16.9693C16.4804 17.149 16.7348 17.25 17 17.25C17.2652 17.25 17.5196 17.149 17.7071 16.9693C17.8946 16.7896 18 16.5458 18 16.2917V6.70833C17.9984 6.5831 17.9712 6.45938 17.92 6.34417Z" fill="#006764"/>
                                                                        </svg>
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </article>
                                                );
                                            })}
                                        </div>
                                    </div>
                                );
                            });
                        })()}
                    </div>
                </div>
            
            </div>
        </div>
    </section>

    <!-- Slider de promociones -->
    <PromotionSlider />


    <section class="max-w-7xl mx-auto py-8 sliderArticulosRelacionados px-4 md:px-6">
        <span class="mb-2 uppercase text-[12px] font-medium leading-[20px] tracking-[0.1px] text-[var(--color-accent)]">BLOG</span>
        <h3 class=" mb-6 font-normal text-[28px] text-[#212121]">Explora artículos y noticias sobre tecnología médica, innovación y cuidado especializado para mejorar la salud y el bienestar.</h3>
        <SlideArticles articulos={articulos} />
    </section>
    
</Layout>


<!-- Popup de Evento -->
<div id="event-popup-overlay" class="fixed inset-0 z-50 hidden">
    <!-- Background with blur and gradient -->
    <div 
        id="event-blurred-background" 
        class="absolute inset-0 transition-all duration-300"
        style="background: linear-gradient(0deg, rgba(0, 0, 0, 0.50) 0%, rgba(0, 0, 0, 0.50) 100%); filter: blur(8px);"
    >
    </div>
    
    <!-- Popup Content -->
    <div id="PopupContent" class="relative z-10 flex items-center justify-center min-h-screen p-4 h-[85%] md:h-[85%] lg:h-auto md:mt-12 overflow-y-auto">
        <div class="bg-white rounded-lg shadow-xl max-w-4xl w-full overflow-auto relative h-[85%] md:h-[85%] lg:h-auto">
                <!-- Botón cerrar en esquina superior derecha del popup -->
                <button 
                    id="close-event-popup"
                    class="absolute top-4 right-4 text-white text-2xl leading-none bg-[#261819] border-none cursor-pointer z-10 px-2 py-1 rounded"
                >
                    ×
                </button>
                
                <!-- Contenido del popup -->
                <div class="flex flex-col lg:flex-row relative">
                    <!-- Imagen izquierda que cubre toda la altura -->
                    <div class="lg:w-1/2 relative">
                        <img
                            id="event-popup-image"
                            src=""
                            alt="Evento"
                            class="w-full h-auto min-h-0 object-contain md:h-64 md:min-h-[500px] md:object-cover lg:h-full lg:min-h-[500px] lg:object-cover"
                        />
                    </div>
                    
                    <!-- Contenido derecha -->
                    <div class="lg:w-1/2 p-4 lg:p-8">

                        <div class="mb-2" id="event-popup-text">

                            <p class="text-[var(--color-accent)] font-lato text-[14px] uppercase font-medium mb-2"> EXCLUSIVIDAD MÉDICA </p>
                            <!-- Título -->
                            <h2 id="event-popup-title" class="text-[#261819] font-lato text-[22px]  mb-4">
                                Título del evento
                            </h2>
                            
                            <!-- Descripción -->
                            <p id="event-popup-description" class="text-[#5A4043] text-[16px] leading-relaxed" style="font-family: Lato;">
                                Descripción del evento
                            </p>
                        </div>
                        

                        <BaseForm id="events-form" class="space-y-8  rounded">
                            <FormField
                            label="Nombre completo"
                            name="name"
                            placeholder="Ej: Dra. Carolina Ávila"
                            />
                            <FormField
                            label="Correo electrónico"
                            name="email"
                            type="email"
                            placeholder="Ej: carolina.avila@hospitalcardio.mx"
                            />
                            <CheckboxField
                            id="aviso"
                            label="He leído y acepto el"
                            link="/aviso-de-privacidad"
                            />
                            <SubmitButton text="Acceder a mis beneficios"></SubmitButton>
                        </BaseForm>

                        <script type="module">
                            import { initForm } from "/scripts/formValidator.js";

                            document.addEventListener("DOMContentLoaded", () => {
                                initForm("events-form");
                            });
                        </script>    
                    </div>
                </div>

                <div id="status" class="text-center mt-2 text-sm"></div>
        </div>
    </div>
</div>


<script>
    import dayjs from 'dayjs';
    import 'dayjs/locale/es';

    // Configurar dayjs en español
    dayjs.locale('es');

    // Script unificado para eventos, popup y calendario
    document.addEventListener('DOMContentLoaded', function() {
        // console.log('DOM loaded - inicializando componentes');

        // Popup
        const popupOverlay = document.getElementById('event-popup-overlay');
        const popupTitle = document.getElementById('event-popup-title');
        const popupDescription = document.getElementById('event-popup-description');
        const popupImage = document.getElementById('event-popup-image');
        const closePopupBtn = document.getElementById('close-event-popup');
        const mainContent = document.querySelector('section');
        
        // Formulario
        const form = document.getElementById("events-form");
        const status = document.getElementById("status");
        
        // Resetear popup a estado inicial
        function resetPopupToInitial() {
            if (popupTitle) popupTitle.textContent = 'Título del evento';
            if (popupDescription) popupDescription.textContent = 'Descripción del evento';
            
            if (popupImage) {
                popupImage.style.display = 'block';
            }
            
            // Restaurar formulario
            if (form) {
                form.style.display = 'block';
                form.reset();
                document.querySelector('.form-container').classList.remove('hidden');
                document.querySelector('.form-success').classList.add('hidden');
                document.querySelector('.form-error').classList.add('hidden');
            }
            
            // Restaurar columnas
            const leftColumn = document.querySelector('.lg\\:w-1\\/2.relative');
            const rightColumn = document.querySelector('.lg\\:w-1\\/2.p-4');
            if (leftColumn) leftColumn.style.display = 'block';
            if (rightColumn) rightColumn.style.display = 'block';
            
            // Ocultar status
            if (status) {
                status.innerHTML = '';
                status.style.display = 'none';
            }
        }
        
        // Abrir popup
        function openEventPopup(eventData) {
            if (!popupOverlay) return;

            resetPopupToInitial();
            
            // Actualizar contenido
            if (popupImage && eventData.img) popupImage.src = eventData.img; popupImage.alt = eventData.title || 'Evento';
            if (popupTitle && eventData.title) popupTitle.textContent = eventData.title;
            if (popupDescription && eventData.description) popupDescription.textContent = eventData.description;
            
            if (mainContent) mainContent.style.filter = 'blur(8px)';
                popupOverlay.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
        }
        
        // Cerrar popup
        function closeEventPopup() {
            if (!popupOverlay) return;
            
            if (mainContent) mainContent.style.filter = 'none';
            popupOverlay.classList.add('hidden');
            document.body.style.overflow = 'auto';
            resetPopupToInitial();


---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import { ESPECIALTIES } from "@lib/site.ts";
const especialidades = ESPECIALTIES;
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import Breadcrumb from '@components/navigation/Breadcrumb.astro';
---

<Layout title="Especialidades">
    <Fragment slot="head">
        <BreadcrumbSchema
        items={[
            { name: 'Inicio', url: 'https://www.medrent.mx' },
            { name: 'Especialidades', url: 'https://www.medrent.mx/especialidades' },
        ]}
        />
    </Fragment>


    <div class="max-w-7xl m-auto ">
    <section class="relative w-full h-auto mb-8"> 
        <!-- Breadcrumb sobre la imagen -->
        <div class="absolute w-full z-2">
            <Breadcrumb
            textColor="text-white"
            items={[
                { name: "INICIO", href: "/" },
                { name: "ESPECIALIDADES" }
            ]}
            />
        </div>

        <div class="flex flex-col w-full h-auto gap-6 md:flex-row bg-[var(--color-primary)] rounded-b-[24px] pt-16 pb-6 px-4 md:pt-16 md:pb-8 md:px-6 lg:py-[50px] lg:px-[135px]"> 
            <!-- Columna 1.2: Imagen (actual izquierda) --> 
            <div class="w-full flex flex-col justify-center gap-2 z-10 "> 
                <h1 class="font-bold text-[28px] md:text-[32px] font-light text-white text-left w-full" style="background: linear-gradient(91deg, #69D8D3 0.22%, #AFFFFA 74.55%); background-clip: text; -webkit-background-clip: text; -webkit-text-fill-color: transparent;"> 
                    Nuestras especialidades
                </h1> 
                <h3 class="text-[22px] text-white">Tecnología médica para diagnóstico, terapia y rehabilitación</h3>
                <p class="text-[14px] text-white tracking-[0.5px] text-base">
                    En MedRent ofrecemos soluciones avanzadas en neurociencias, neuromodulación y rehabilitación, diseñadas para acompañar la práctica médica con precisión clínica, confiabilidad tecnológica y soporte especializado.
                </p> 
                <a
                href="/contacto"
                class="bg-white border border-[var(--color-primary)] text-[var(--color-primary)] py-3 px-4 m-0 rounded font-bold transition cursor-pointer flex justify-center gap-2 w-full md:w-fit mt-4"
                aria-label="Recibe asesoría personalizada"
                >
                    Recibe asesoría personalizada
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                        <path d="M17.92 6.62C17.8185 6.37565 17.6243 6.18147 17.38 6.08C17.2598 6.02876 17.1307 6.00158 17 6H7C6.73478 6 6.48043 6.10536 6.29289 6.29289C6.10536 6.48043 6 6.73478 6 7C6 7.26522 6.10536 7.51957 6.29289 7.70711C6.48043 7.89464 6.73478 8 7 8H14.59L6.29 16.29C6.19627 16.383 6.12188 16.4936 6.07111 16.6154C6.02034 16.7373 5.9942 16.868 5.9942 17C5.9942 17.132 6.02034 17.2627 6.07111 17.3846C6.12188 17.5064 6.19627 17.617 6.29 17.71C6.38296 17.8037 6.49356 17.8781 6.61542 17.9289C6.73728 17.9797 6.86799 18.0058 7 18.0058C7.13201 18.0058 7.26272 17.9797 7.38458 17.9289C7.50644 17.8781 7.61704 17.8037 7.71 17.71L16 9.41V17C16 17.2652 16.1054 17.5196 16.2929 17.7071C16.4804 17.8946 16.7348 18 17 18C17.2652 18 17.5196 17.8946 17.7071 17.7071C17.8946 17.5196 18 17.2652 18 17V7C17.9984 6.86932 17.9712 6.74022 17.92 6.62Z" fill="var(--color-primary)"/>
                    </svg>
                </a>
            </div>

            <!-- Columna 1.1: Texto (actual derecha) --> 
            <div class="w-full overflow-hidden" >
                <img src="/temp/especialidades/especialidadesHero.png" alt="especialidades" class="rounded-[16px] mx-auto" style="background: linear-gradient(91deg, #69D8D3 0.22%, #AFFFFA 74.55%);"/>
            </div> 
        </div>
    </section>

    <section>
        {especialidades.map((categoria: any, index: number) => (
            <div class={`flex flex-col md:flex-row w-full bg-white rounded-lg gap-6 p-4 md:p-6 lg:px-[135px] lg:py-8 ${index % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
                <div class="w-full md:w-1/2 lg:w-2/5 flex flex-col justify-center"> 
                    <div class="py-6"> 
                        <p class="text-[var(--color-accent)] font-bold text-[14px] md:text-[14px] uppercase ">{String(index + 1).padStart(2, '0')}</p> 
                        <h3 class=" text-[24px] md:text-[28px] lg:text-[36px] font-light text-[#261819]"> 
                            {categoria.Nombre} 
                        </h3> 
                        <p class="text-[var(--color-green-dark)] text-[16px] font-normal mb-4 leading-relaxed"> 
                            {categoria.Descripcion}
                        </p> 
                        {/* <div> 
                            <h4 class="font-medium text-[#212121] text-base">Aplicaciones:</h4> 
                            <p class="text-[#5A4043] text-[16px] italic font-normal leading-relaxed"> Ultrasonido Vascular </p> 
                        </div> */}
                    </div>
                    <div class="mt-4 sm:mt-2"> 
                        <a href={`/especialidades/${categoria.Slug}`} class="items-center align-center justify-center flex bg-[var(--color-primary)] hover:bg-[var(--color-accent)] text-white text-[14px] font-bold not-italic px-4 py-3 transition-colors w-full md:w-fit gap-2 self-start rounded-[4px]">
                            Ver aplicaciones
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none"> 
                                <path d="M13.44 4.965C13.3638 4.78174 13.2182 4.63611 13.035 4.56C12.9448 4.52157 12.848 4.50118 12.75 4.5H5.24995C5.05104 4.5 4.86028 4.57902 4.71962 4.71967C4.57897 4.86032 4.49995 5.05109 4.49995 5.25C4.49995 5.44891 4.57897 5.63968 4.71962 5.78033C4.86028 5.92098 5.05104 6 5.24995 6H10.9425L4.71745 12.2175C4.64716 12.2872 4.59136 12.3702 4.55329 12.4616C4.51521 12.553 4.49561 12.651 4.49561 12.75C4.49561 12.849 4.51521 12.947 4.55329 13.0384C4.59136 13.1298 4.64716 13.2128 4.71745 13.2825C4.78718 13.3528 4.87013 13.4086 4.96152 13.4467C5.05292 13.4847 5.15095 13.5043 5.24995 13.5043C5.34896 13.5043 5.44699 13.4847 5.53839 13.4467C5.62978 13.4086 5.71273 13.3528 5.78245 13.2825L12 7.0575V12.75C12 12.9489 12.079 13.1397 12.2196 13.2803C12.3603 13.421 12.551 13.5 12.75 13.5C12.9489 13.5 13.1396 13.421 13.2803 13.2803C13.4209 13.1397 13.5 12.9489 13.5 12.75V5.25C13.4988 5.15199 13.4784 5.05517 13.44 4.965Z" fill="white">
                                </path> 
                            </svg> 
                        </a> 
                    </div> 
                </div>  
                <div class="w-full md:w-1/2 lg:w-3/5 h-64 md:h-auto min-h-[240px] relative overflow-hidden">  
                    <img src={`/temp/especialidades/${categoria.Image}`} alt={categoria.Nombre} class="w-full h-full object-cover rounded-[4px]"/> 
                </div> 

            </div>
        ))}
    </section>
    </div>
</Layout>
---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import { METRICS } from '@lib/site';
const metrics = METRICS;
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import Breadcrumb from '@components/navigation/Breadcrumb.astro';

const baseUrl = Astro.site ? new URL(Astro.site).origin : "https://www.medrent.mx";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const breadcrumbId = `${canonicalUrl}#breadcrumb`;
const logoUrl = `${baseUrl}/favicon-512.png`;
---

<Layout
  title="Acerca de MedRent | Distribución de equipo médico en México"
  description="Conoce MedRent y cómo acercamos tecnología médica con soporte y capacitación. Experiencia en distribución y acompañamiento a especialistas."
  keywords="MedRent; equipo médico; distribución; soporte biomédico; capacitación"
  ogImage={logoUrl}
>
    <Fragment slot="head">
        <BreadcrumbSchema
        items={[
            { name: 'Inicio', url: `${baseUrl}/` },
            { name: 'Acerca de nosotros', url: `${baseUrl}/acerca-de-nosotros` },
        ]}
        id={breadcrumbId}
        />
        <script type="application/ld+json" set:html={
          JSON.stringify({
            "@context": "https://schema.org",
            "@graph": [
              {
                "@type": ["WebPage", "AboutPage"],
                "@id": `${canonicalUrl}#webpage`,
                "url": canonicalUrl,
                "name": "Acerca de MedRent | Distribución de equipo médico en México",
                "description":
                  "Conoce MedRent y cómo acercamos tecnología médica con soporte y capacitación. Experiencia en distribución y acompañamiento a especialistas.",
                "isPartOf": { "@id": `${baseUrl}/#website` },
                "about": { "@id": `${baseUrl}/#organization` },
                "inLanguage": "es-MX",
                "breadcrumb": { "@id": breadcrumbId },
                "primaryImageOfPage": {
                  "@type": "ImageObject",
                  "url": logoUrl,
                },
              },
            ],
          })
        }></script>
    </Fragment>

    <div class="absolute w-full z-2">
        <Breadcrumb
        textColor="text-white"
        items={[
            { name: "INICIO", href: "/" },
            { name: "ACERCA DE NOSOTROS" }
        ]}
        />
    </div>
    
    <section aria-labelledby="about-hero-title" class="max-w-[1280px] w-full flex flex-col justify-start bg-[#000] min-h-[350px] mx-auto" style="border-radius:0 0 24px 24px;"> 
        <div class="w-full flex flex-col gap-4 py-[32px] px-4 mt-9 sm:px-[16px] md:px-[135px] md:py-[32px] sm:py-[32px] sm:px-[24px] m-auto"> 
            <div class="text-left flex flex-col gap-4">
                <h1 class="text-[var(--color-accent)] font-bold text-[14px] md:text-[14px] uppercase mt-8">LÍDERES EN TECNOLOGÍA MÉDICA</h1>
                <h2 class="text-[24px] font-bold text-[var(--color-white)] tracking-tight">
                    DISTRIBUIMOS LAS MEJORES MARCAS DE EQUIPO MÉDICO
                </h2>
                <p class="text-[var(--color-gray)] text-base tracking-[0.5px] ">Contamos el respaldo de más de 50 años de experiencia en el mercado de distribución de equipo médico.</p>
            </div>
            <a
            href="/productos"
            class="bg-[var(--color-white)] text-[var(--color-primary)] py-3 px-4 m-0 rounded font-bold transition cursor-pointer gap-4 flex justify-start items-center w-fit"
            aria-label="Explora nuestro catálogo"
            >
                Explora nuestro catálogo

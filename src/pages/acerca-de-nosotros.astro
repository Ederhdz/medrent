            <!-- Contenido -->
            <h2 class="mb-4 font-semibold text-gray-900 text-[24px]  md:text-[28px] tracking-[0.5px] text-center lg:text-left">
            Más de 50 años conectando tecnología médica con especialistas en salud
            </h2>

            <div>
                <p class="mb-4 text-base tracking-[0.5px] text-center lg:text-left ">
                En MedRent distribuimos equipos líderes en
                <strong class="text-[var(--color-primary)]">Neurofisiología, Cardiología, Ultrasonido, Neurología y Rehabilitación, </strong>
                ofreciendo soluciones confiables respaldadas por décadas de experiencia.
                </p>

                <p class="text-base sm:text-center tracking-[0.5px] text-center lg:text-left">
                    Fundada en  <strong>1960</strong> bajo  <strong>Laboratorios Mexicanos Colliere.</strong>
                </p>
            </div>

            <!-- Botón -->
            <div class="flex flex-col sm:flex-row md:flex-row lg:flex-row w-full items-center justify-between gap-6">
                <a
                    href="/productos"
                    class="w-full sm:w-1/2 bg-[#006764] border border-[var(--color-primary)] text-[#FFF] py-3 px-4 m-0 rounded font-bold transition cursor-pointer flex justify-center gap-2 hover:bg-[var(--color-primary)] hover:text-white lg:hidden"
                    aria-label="Explora nuestro catálogo"
                >
                    Ver equipos disponibles
                </a>
                <a
                    href="/nuestras-marcas"
                    class="w-full sm:w-1/2 bg-white border border-[var(--color-primary)] text-[var(--color-primary)] py-3 px-4 m-0 rounded font-bold transition cursor-pointer flex justify-center gap-2 hover:bg-[var(--color-primary)] hover:text-white lg:hidden"
                    aria-label="Explora nuestro catálogo"
                >
                Marcas especializadas
                </a>
            </div>
        </div>
    </section>

    <section class="py-6 px-8 max-w-7xl mx-auto flex flex-col gap-6">
        <div class="glide" id="MetricsSlider">
            <div class="glide__track" data-glide-el="track">
                <ul class="glide__slides">
                    { metrics.map((metric) => (
                        <li class="rounded-[16px] py-8 px-6 text-center bg-[#87F4EF]" style="white-space: normal;">
                            <div class="flex flex-col h-full justify-center gap-2">
                                <span class="text-4xl font-bold text-gray-900 tracking-[0.5px]">
                                    {metric.value}
                                </span>
                                <p class="text-base font-base text-gray-700 tracking-[0.5px] uppercase w-auto">
                                    {metric.label}
                                </p>
                            </div>
                        </li>
                    )) }
                </ul>
            </div>
        </div>
    </section>

    <section aria-labelledby="mission-values-title" style="background: linear-gradient(180deg, #FFF 0%, var(--Schemes-Primary-Fixed, #87F4EF) 50%);">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-6">
            <!-- Grid -->
            <div class="grid gap-6 md:grid-cols-2"> 
                <!-- Misión -->
                <article class="rounded-xl bg-white p-6" style="background: var(--gradient-surface-dark);">
                    <h4 class="text-[var(--color-secondary)] font-bold text-[14px] md:text-[14px] uppercase "> MEDRENT</h4>
                    <h3 class="mb-4 text-[28px]  font-bold text-[var(--color-white)]"> Misión</h3>
                    <p class="text-sm leading-relaxed text-[var(--color-gray)] text-[16px]  tracking-[0.5px]">
                    Brindar al profesional de la salud acceso ágil a equipos y dispositivos de calidad superior, elevando la atención al paciente. Seleccionamos solo marcas confiables y ofrecemos formación y soporte continuo para maximizar su impacto en el cuidado.
                    </p>
                </article>

                <!-- Valores -->
                <article class="rounded-xl bg-white p-6" style="background: var(--gradient-surface-dark);">
                    <h4 class="text-[var(--color-secondary)] font-bold text-[14px] md:text-[14px] uppercase "> MEDRENT</h4>
                    <h3 class="mb-4 text-[28px]  font-bold text-[var(--color-white)]"> Valores</h3>
                    <ul class="space-y-2 text-sm  text-[var(--color-gray)] list-disc list-inside  text-[16px]  tracking-[0.5px]">
                        <li><strong class="">Compromiso:</strong> actitudes que respaldan cada promesa hecha.</li>
                        <li><strong>Integridad:</strong> coherencia entre lo que decimos y hacemos.</li>
                        <li><strong>Honestidad:</strong> claridad plena, sin confusiones ni engaños.</li>
                        <li><strong>Ética en todos lados (“Ethics everywhere”):</strong> en cada decisión, acción y relación.</li>
                    </ul>
                </article>
            </div>
        </div>
    </section>
    <script type="module">
        const slider = document.querySelector('#MetricsSlider');
        if (!slider) {
            // noop
        } else {
            (async () => {
                const { default: Glide } = await import('@glidejs/glide');
                new Glide(slider, {
                    type: 'carousel',
                    perView: 5,
                    gap: 24,
                    autoplay: 2000,
                    hoverpause: true,
                    rewind: false,
                    breakpoints: {
                        1024: {
                            perView: 3
                        },
                        640: {
                            perView: 1
                        }
                    }
                }).mount();
            })().catch(() => {});
        }
    </script>



</Layout>
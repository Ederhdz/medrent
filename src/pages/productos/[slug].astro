    // Funcionalidad para cambiar imagen principal al hacer clic en miniaturas y scroll en galería
    document.addEventListener('DOMContentLoaded', function() {
        // Miniaturas: cambiar imagen principal al hacer clic y resaltar la seleccionada
        const thumbnails = document.querySelectorAll('#thumbnails-scroll button[data-index]');
        // Desktop/Tablet main image
        let mainImage = document.getElementById('main-image-desktop');
        // Al cargar, marcar la primera miniatura como seleccionada
        if (thumbnails.length) {
            thumbnails.forEach(b => {
                b.style.borderColor = '';
                b.style.borderWidth = '';
            });
            thumbnails[0].style.borderColor = '#006764';
            thumbnails[0].style.borderWidth = '3px';
        }
        thumbnails.forEach(btn => {
            btn.addEventListener('click', function() {
                // Quitar borde de seleccion a todas
                thumbnails.forEach(b => {
                    b.style.borderColor = '';
                    b.style.borderWidth = '';
                });
                // Agregar borde de seleccion al actual
                this.style.borderColor = '#006764';
                this.style.borderWidth = '3px';
                const type = this.getAttribute('data-type');
                const src = this.getAttribute('data-thumbnail');
                // Reemplazar el nodo principal por el tipo correcto (img o video)
                const container = document.getElementById('main-media-container');
                if (!container) return;
                if (type === 'image') {
                    if (mainImage && mainImage.tagName === 'IMG') {
                        mainImage.src = src;
                        mainImage.setAttribute('data-type', 'image');
                        mainImage.classList.remove('hidden');
                    } else {
                        // Si el actual es video, reemplazar por img
                        const img = document.createElement('img');
                        img.src = src;
                        img.alt = '';
                        img.className = 'w-full h-full object-contain max-h-[600px] rounded-lg';
                        img.id = 'main-image-desktop';
                        img.setAttribute('data-type', 'image');
                        container.innerHTML = '';
                        container.appendChild(img);
                        mainImage = img;
                    }
                } else if (type === 'video') {
                    if (mainImage && mainImage.tagName === 'VIDEO') {
                        mainImage.src = src;
                        mainImage.setAttribute('data-type', 'video');
                        mainImage.classList.remove('hidden');
                    } else {
                        // Si el actual es img, reemplazar por video
                        const video = document.createElement('video');
                        video.src = src;
                        video.controls = true;
                        video.className = 'w-full h-full object-contain max-h-[600px] rounded-lg';
                        video.id = 'main-image-desktop';
                        video.setAttribute('data-type', 'video');
                        container.innerHTML = '';
                        container.appendChild(video);
                        mainImage = video;
                    }
                }
            });
        });


        const btnsVerPopUpImagenes = document.querySelectorAll('.btnVerPopUpImagenes');
        btnsVerPopUpImagenes.forEach(btn => {
            btn.addEventListener('click', function(e) {
                const overlay = document.getElementById('gallery-popup-overlay');
                if (overlay) overlay.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
                // Obtener imágenes desde data-imagenes (array de strings)
                let images = [];
                try {
                  images = this.getAttribute('data-imagenes') ? JSON.parse(this.getAttribute('data-imagenes')) : [];
                  if (!Array.isArray(images)) images = [];

                  
                } catch (err) {
                  images = [];
                }
                // Recuperar el índice de la miniatura con +N
                const index = this.querySelector('button')?.getAttribute('data-index');
                const startIndex = index ? parseInt(index, 10) : 6;
                openGalleryPopup(images, startIndex);
            });
        });
    });
</script>


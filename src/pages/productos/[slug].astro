<script>
  document.addEventListener('DOMContentLoaded', function() {
    const slider = document.getElementById('glider-slideimagenesProducto');
    const counter = document.getElementById('mobile-gallery-counter');
    if (!slider || !counter) return;

    const slides = slider.querySelectorAll('li');
    const total = slides.length;
    if (!total) return;

    let rafId = 0;
    let snapTimer = 0;
    const updateCounter = () => {
      const width = slider.clientWidth || 1;
      const index = Math.min(total - 1, Math.max(0, Math.round(slider.scrollLeft / width)));
      counter.textContent = `${index + 1} / ${total}`;
      return { width, index };
    };

    const onScroll = () => {
      if (rafId) return;
      rafId = requestAnimationFrame(() => {
        const { width, index } = updateCounter();
        if (snapTimer) window.clearTimeout(snapTimer);
        snapTimer = window.setTimeout(() => {
          slider.scrollTo({ left: index * width, behavior: 'smooth' });
        }, 80);
        rafId = 0;
      });
    };

    slider.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', updateCounter);
    updateCounter();
  });

  // Funcionalidad para cambiar imagen principal al hacer clic en miniaturas y scroll en galería
  document.addEventListener('DOMContentLoaded', function() {
    const thumbnails = document.querySelectorAll('[data-thumbnail]');
    const mainMediaContainer = document.getElementById('main-media-container');
    const thumbnailsScroll = document.getElementById('thumbnails-scroll');
    const scrollDownBtn = document.getElementById('scroll-down-thumbnails');
    const scrollUpBtn = document.getElementById('scroll-up-thumbnails');
    
    thumbnails.forEach(thumbnail => {
      thumbnail.addEventListener('click', function() {
        const newSrc = this.dataset.thumbnail;
        const type = this.dataset.type;
        if (mainMediaContainer && newSrc) {
          // Actualizar el contenido del contenedor principal
          if (type === 'image') {
            mainMediaContainer.innerHTML = `<img src='${newSrc}' alt='' class='w-full h-full object-contain max-h-[600px]' id='main-image' data-type='image' />`;
          } else if (type === 'video') {
            mainMediaContainer.innerHTML = `<video src='${newSrc}' controls class='w-full h-full object-contain max-h-[600px]' id='main-image' data-type='video'></video>`;
          }
          // Actualizar estilos de selección
          thumbnails.forEach(thumb => {
            thumb.className = 'w-20 h-20 bg-white rounded overflow-hidden transition-colors cursor-pointer border border-[var(--color-surface-light)] hover:border-[var(--color-primary)]';
          });
          // Marcar como seleccionado el thumbnail actual
          this.className = 'w-20 h-20 bg-white rounded overflow-hidden transition-colors cursor-pointer border-3 border-[var(--color-primary)]';
        }
      });
    });

    // Scroll hacia abajo en la galería de miniaturas (5 miniaturas)
    if (scrollDownBtn && thumbnailsScroll) {
      scrollDownBtn.addEventListener('click', function() {
        const thumbnailHeight = 80 + 12; // 80px alto + 12px gap
        thumbnailsScroll.scrollBy({ top: thumbnailHeight * 5, behavior: 'smooth' });
      });
    }
    // Scroll hacia arriba en la galería de miniaturas (5 miniaturas)
    if (scrollUpBtn && thumbnailsScroll) {
      scrollUpBtn.addEventListener('click', function() {
        const thumbnailHeight = 80 + 12;
        thumbnailsScroll.scrollBy({ top: -thumbnailHeight * 5, behavior: 'smooth' });
      });
    }  
  });
</script>  





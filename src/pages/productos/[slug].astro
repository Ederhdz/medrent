    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        const toggleButtons = document.querySelectorAll('[data-share-toggle]');
        const encodedUrl = encodeURIComponent(window.location.href);

        toggleButtons.forEach((button) => {
          const container = button.closest(".relative");
          if (!container) return;

          const closeBtn = container.querySelector('[data-share-close]');
          const actions = container.querySelector('[data-share-actions]');
          const tooltip = container.querySelector('[data-copy-tooltip]');
          const copyBtn = container.querySelector('[data-copy-url]');
          const facebook = container.querySelector('[data-share-facebook]');
          const linkedin = container.querySelector('[data-share-linkedin]');

          if (facebook instanceof HTMLAnchorElement) {
            facebook.href = `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`;
          }

          if (linkedin instanceof HTMLAnchorElement) {
            linkedin.href = `https://www.linkedin.com/shareArticle?mini=true&url=${encodedUrl}`;
          }

          button.addEventListener("click", () => {
            button.classList.add("opacity-0", "pointer-events-none");
            actions?.classList.remove("opacity-0", "pointer-events-none");
            actions?.classList.add("opacity-100");
          });

          closeBtn?.addEventListener("click", () => {
            button.classList.remove("opacity-0", "pointer-events-none");
            actions?.classList.add("opacity-0", "pointer-events-none");
            actions?.classList.remove("opacity-100");
          });

          copyBtn?.addEventListener("click", async () => {
            await navigator.clipboard.writeText(window.location.href);
            tooltip?.classList.remove("opacity-0");
            tooltip?.classList.add("opacity-100");

            setTimeout(() => {
              tooltip?.classList.add("opacity-0");
              tooltip?.classList.remove("opacity-100");
            }, 1500);
          });
        });
      });
    </script>


    
    


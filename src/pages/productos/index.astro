---
export const prerender = false;

import Layout from "@layouts/Layout.astro";
import BreadcrumbSchema from "@components/seo/BreadcrumbSchema.astro";
import Breadcrumb from "@components/navigation/Breadcrumb.astro";
import PLPLayout from "@components/product/PLPLayout.astro";
import ProductGrid from "@components/product/ProductGrid.astro";
import SidebarFilters from "@components/product/SidebarFilters.astro";

import { getProducts } from "@server/api/products";
import { getBrands } from "@server/api/brands";
import { getCategories } from "@server/api/categories";
import { getAllSubcategories } from "@server/api/subcategories";

/* ---------------- QUERY PARAMS ---------------- */

const url = new URL(Astro.request.url);

const brandQuery = url.searchParams.get("brand")?.split(",") || [];
const categoryQuery = url.searchParams.get("category")?.split(",") || [];
const subcategoryQuery =
  url.searchParams.get("subcategory")?.split(",") || [];

/* ---------------- FETCH DATA ---------------- */

const products = await getProducts({
  brands: brandQuery,
  categories: categoryQuery,
  subcategories: subcategoryQuery,
});

const brandsData = await getBrands();
const categoriesData = await getCategories();
const subcategoriesData = await getAllSubcategories();

const baseUrl = Astro.site ? new URL(Astro.site).origin : "https://www.medrent.mx";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const breadcrumbId = `${canonicalUrl}#breadcrumb`;
const logoUrl = `${baseUrl}/favicon-512.png`;
const heroImageUrl = `${baseUrl}/temp/HeroPLP.png`;
---

<Layout
  title="Catálogo de productos | Equipos médicos y consumibles | MedRent"
  description="Explora equipos por especialidad, aplicación y marca. Tecnología médica con soporte, instalación y opciones de financiamiento."
  keywords="catálogo equipo médico; productos médicos; consumibles; MedRent"
  ogImage={heroImageUrl}
>
  <Fragment slot="head">
    <BreadcrumbSchema
      items={[
        { name: "Inicio", url: `${baseUrl}/` },
        { name: "Productos", url: `${baseUrl}/productos` },
      ]}
      id={breadcrumbId}
    />
    <script type="application/ld+json" set:html={
      (() => {
        const slice = Array.isArray(products) ? products.slice(0, 12) : [];
        const itemListElement = slice.map((p, index) => {
          const slug = p?.slug;
          const pdpUrl = slug ? `${baseUrl}/productos/${slug}` : canonicalUrl;
          const imageUrl = Array.isArray(p?.gallery) ? p.gallery[0] : undefined;
          return {
            "@type": "ListItem",
            position: index + 1,
            item: {
              "@type": ["MedicalDevice", "Product"],
              "@id": `${pdpUrl}#product`,
              name: p?.name || "Producto",
              url: pdpUrl,
              image: imageUrl ? [imageUrl] : undefined,
            },
          };
        });

        return JSON.stringify({
          "@context": "https://schema.org",
          "@graph": [
            {
              "@type": "WebPage",
              "@id": `${canonicalUrl}#webpage`,
              url: canonicalUrl,
              name: "Productos | Equipos médicos y consumibles | MedRent",
              description:
                "Explora equipos por especialidad, aplicación y marca. Tecnología médica con soporte, instalación y opciones de financiamiento.",
              isPartOf: { "@id": `${baseUrl}/#website` },
              about: { "@id": `${baseUrl}/#organization` },
              inLanguage: "es-MX",
              breadcrumb: { "@id": breadcrumbId },
              mainEntity: { "@id": `${canonicalUrl}#itemlist` },
              primaryImageOfPage: {
                "@type": "ImageObject",
                url: heroImageUrl,
              },
            },
            {
              "@type": "CollectionPage",
              "@id": `${canonicalUrl}#collection`,
              url: canonicalUrl,
              name: "Productos | Equipos médicos y consumibles | MedRent",
              description:
                "Explora equipos por especialidad, aplicación y marca. Tecnología médica con soporte, instalación y opciones de financiamiento.",
              isPartOf: { "@id": `${baseUrl}/#website` },
              about: { "@id": `${baseUrl}/#organization` },
              inLanguage: "es-MX",
              mainEntity: { "@id": `${canonicalUrl}#itemlist` },
            },
            {
              "@type": "ItemList",
              "@id": `${canonicalUrl}#itemlist`,
              name: "Productos — listado",
              itemListOrder:
                "https://schema.org/ItemListOrderAscending",
              itemListElement,
            },
          ],
        });
      })()
    }></script>
  </Fragment>

  <!-- HERO -->
  <section class="relative w-full h-[140px] max-w-7xl mx-auto overflow-hidden">
    <div class="absolute inset-0 heroproductos">
      <Breadcrumb
        textColor="text-white"
        items={[
          { name: "INICIO", href: "/" },
          { name: "PRODUCTOS" },
        ]}
      />
      <img
        src="/temp/HeroPLP.png"
        alt="Todos los productos"
        class="w-full h-full object-cover rounded-b-[24px]"
      />
    </div>
  </section>

  <!-- PLP -->
  <PLPLayout title="Productos">
    <Fragment slot="filters">
      <SidebarFilters
        brands={brandsData}
        categories={categoriesData}
        subcategories={subcategoriesData}
      />
    </Fragment>

    <ProductGrid products={products} />
  </PLPLayout>
</Layout>
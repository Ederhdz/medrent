---
import Layout from '@layouts/Layout.astro';
import { strapiFetch } from "@server/strapiClient";
import ArticleCard from '@components/blog/articleCard.astro';
import { BlocksRenderer } from '@strapi/blocks-react-renderer';
import NewBreadcrumb from '@components/newBreadcrumb.astro';


// import { formatDate } from '@lib/utils.js';
// import SocialMedia from '@components/blog/SocialMedia.astro';

const breadcrumbData = [
  
  { name: 'INICIO', url: '/' },
  { name: 'BLOG', url: '/blog' },
  { name: 'ARTÍCULO', url: '' }
];


export async function getStaticPaths() {
  const authors = await strapiFetch('/writers?populate[articles][populate][heroImage]=true&populate[heroImage]=true&populate[articles][populate][writer]=true');

  return authors.data.map((page) => ({
    params: { autor: page.slug },
    props: { 
      author: {
        ...page,
        articles: Array.isArray(page.articles) ? page.articles : [],
      },
    }
  }));
}
const { author } = Astro.props as { author: any };
---

<Layout title="Blog" pageType="blog">
  <Fragment slot="metas">
    <!-- <meta id="description" content={pageDescription}>
    <meta property="og:title" content={pageTitle}>
    <meta property="og:description" content={pageDescription}>
    <meta property="og:type" content="article">
    <meta property="og:image" content={author?.ImagenHeroArticulo?.url ? buildImageUrl(author.ImagenHeroArticulo.url) : "/images/og/default.jpg"}>
    <meta id="twitter:card" content="summary_large_image">
    <meta id="twitter:title" content={pageTitle}>
    <meta id="twitter:description" content={pageDescription}>
    <meta id="twitter:image" content={author?.ImagenHeroArticulo?.url ? buildImageUrl(author.ImagenHeroArticulo.url) : "/images/og/default.jpg"}> -->
  </Fragment>

 <section class="heroAutor max-w-[1280px] w-full flex flex-col items-center justify-center bg-[var(--color-secondary-light)] min-h-[260px] mx-auto" style="border-radius:0 0 24px 24px;">
    <div class="containerHero w-full flex flex-col md:flex-row items-center gap-6 pt-16 px-4 sm:px-6 md:px-8 pb-4 md:pb-6 lg:py-16 lg:px-8">
      <div class="breadcrumb-fixed-wrapper max-w-7xl px-4" style="position:absolute;top:0;left:0;width:100%;z-index:30;pointer-events:auto;">
        <NewBreadcrumb data={breadcrumbData} />
      </div>

      <style>
        .heroAutor { position: relative; }
        .breadcrumb-fixed-wrapper { pointer-events: auto; }
      </style>
      {/* Columna texto */}
      <div class="w-full md:w-1/2 flex flex-col items-start text-left md:px-8 md:py-6">
        <span class="text-sm font-medium text-[var(--color-primary)] tracking-widest mb-2 uppercase font-lato">{author?.speciality || ''}</span>
        <h1 class="text-[#261819] font-lato text-[32px] font-light">{author?.fullName || 'Autor Desconocido'}</h1>
        <p class="text-[#261819] font-lato text-[16px] font-light">
          <BlocksRenderer content={author?.longDescription || []} />
        </p>
      </div>
      {/* Columna imagen */}
      <div class="w-full md:w-1/2 flex justify-center items-center mt-6 md:mt-0">
        <img src={author?.heroImage?.url || ''} alt="Team Medrent" class=" w-full rounded-xl shadow-md" loading="lazy" />
      </div>
    </div>
  </section>


  <main class="max-w-7xl mx-auto px-4 py-4 sm:px-6 sm:py-6 lg:px-8 lg:py-6 xl:px-8 xl:py-6 2xl:px-8 2xl:py-6 ">
    {author.articles.length > 0 ? (
      <section>
        <h2 class="text-[#261819] font-lato text-[28px] font-light mb-4 md:mb-6 mt-4 md:mt-0 uppercase">{author.articles.length} Artículos</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
          {author.articles.map((articulo:any) => (
            // console.log(articulo)
            <ArticleCard article={articulo} />
          ))}
        </div>
      </section>
    ) : (
      <section>
        <h2 class="text-[#261819] font-lato text-[28px] font-light mb-4 md:mb-6 mt-4 md:mt-0 uppercase">{author.articles.length} Artículos</h2>
        <div class="flex flex-col items-center justify-center rounded-[24px] bg-[#FFF8F7] backdrop-blur-[6px] py-12 px-4 md:px-12  mx-auto mt-6 w-full">
          <svg xmlns="http://www.w3.org/2000/svg" width="59" height="59" viewBox="0 0 59 59" fill="none" class="mb-4">

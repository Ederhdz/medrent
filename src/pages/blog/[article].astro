---
export const prerender = false;

import Layout from '@layouts/Layout.astro';
import { strapiFetch } from "@server/strapiClient";
import { formatDate } from '@lib/utils.js';
import SocialMedia from '@components/blog/SocialMedia.astro';
import Newsletter from '@components/FormNewsletter.astro';
// import SlideArticulos from '@components/blog/SlideArticulos.astro';
import { BlocksRenderer } from '@strapi/blocks-react-renderer';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import Breadcrumb from '@components/navigation/Breadcrumb.astro';
import {
  buildClassificationTagByArticleKeyMap,
  getClassificationTag,
} from '@lib/blog/classification';
import ArticleRelatedMobile from '@components/blog/ArticleRelatedMobile.astro';

const slugParam = Astro.params.article;
if (!slugParam) {
  return Astro.redirect("/404");
}

let article: any = null;
try {
  const primary = await strapiFetch(
    `/blog-articles?filters[slug][$eq]=${encodeURIComponent(slugParam)}&filters[isActive][$eq]=true&populate[heroImage]=true&populate[writer][populate][avatar]=true&populate[content][populate]=*`,
  );
  const rows = primary?.data;
  article = Array.isArray(rows) && rows[0] ? rows[0] : null;
} catch (e) {
  console.error("Error blog-articles (artículo SSR, primario):", e);
}
if (!article) {
  try {
    const fallback = await strapiFetch(
      `/blog-articles?filters[slug][$eq]=${encodeURIComponent(slugParam)}&filters[isActive][$eq]=true&populate=*`,
    );
    const rows = fallback?.data;
    article = Array.isArray(rows) && rows[0] ? rows[0] : null;
  } catch (e2) {
    console.error("Error blog-articles (artículo SSR, fallback):", e2);
  }
}

if (!article) {
  return Astro.redirect("/404");
}

let classificationTagByArticleKey = new Map<string, string>();
try {
  const clsRes = await strapiFetch(
    '/article-classifications?pagination[pageSize]=100&sort=tag:asc&populate[articles]=true',
  );
  if (Array.isArray(clsRes?.data)) {
    classificationTagByArticleKey = buildClassificationTagByArticleKeyMap(clsRes.data);
  }
} catch {
  try {
    const clsRes = await strapiFetch('/article-classifications?pagination[pageSize]=100&sort=tag:asc');
    if (Array.isArray(clsRes?.data)) {
      classificationTagByArticleKey = buildClassificationTagByArticleKeyMap(clsRes.data);
    }
  } catch {
    classificationTagByArticleKey = new Map();
  }
}

const classificationLabel = getClassificationTag(article, classificationTagByArticleKey);

const baseUrl = Astro.site ? new URL(Astro.site).origin : "https://www.medrent.mx";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const breadcrumbId = `${canonicalUrl}#breadcrumb`;
const logoUrl = `${baseUrl}/favicon-512.png`;
const heroImageUrl = article?.heroImage?.url || logoUrl;
const authorSlug = article?.writer?.slug || 'team-medrent';
const personId = `${baseUrl}/blog/autor/${authorSlug}#person`;
const postId = `${canonicalUrl}#post`;

// Relacionados: misma clasificación (TAG CMS); si no hay, subcategoría; si no, recientes.
let articulosRelacionados: any[] = [];
const classTagForRelated = getClassificationTag(article, classificationTagByArticleKey);
try {
  const poolRes = await strapiFetch(
    '/blog-articles?populate=*&sort=publishedAt:desc&pagination[pageSize]=100',
  );
  const pool = Array.isArray(poolRes?.data) ? poolRes.data : [];
  const others = pool.filter(
    (a: any) => a.isActive === true && a.slug && a.slug !== article.slug,
  );

  let picked: any[] = [];
  if (classTagForRelated) {
    picked = others.filter(
      (a: any) => getClassificationTag(a, classificationTagByArticleKey) === classTagForRelated,
    );
  }
  if (picked.length === 0 && article?.subcategory?.slug) {
    picked = others.filter((a: any) => a.subcategory?.slug === article.subcategory.slug);
  }
  if (picked.length === 0) {
    picked = others;
  }
  articulosRelacionados = picked.slice(0, 15);
} catch (error) {
  console.error('Error fetching related articles:', error);
  articulosRelacionados = [];
}

/** Total de artículos activos del mismo autor (no relacionados + 1). */
let authorArticleTotal = 1;
const writerSlugForCount = article?.writer?.slug;
if (writerSlugForCount) {
  const countActiveByWriter = (list: unknown[]) =>
    list.filter(
      (a: any) => a.isActive === true && a.writer?.slug === writerSlugForCount,
    ).length;
  try {
    const countRes = await strapiFetch(
      `/blog-articles?filters[writer][slug][$eq]=${encodeURIComponent(writerSlugForCount)}&pagination[pageSize]=500&fields[0]=slug&fields[1]=isActive`,
    );
    const list = Array.isArray(countRes?.data) ? countRes.data : [];
    const n = list.filter((a: { isActive?: boolean }) => a.isActive === true).length;
    if (n > 0) authorArticleTotal = n;
  } catch {
    try {
      const all = await strapiFetch(
        "/blog-articles?pagination[pageSize]=500&populate[writer]=true",
      );
      const list = Array.isArray(all?.data) ? all.data : [];
      const n = countActiveByWriter(list);
      if (n > 0) authorArticleTotal = n;
    } catch {
      authorArticleTotal = 1;
    }
  }
}
---

<Layout
  title={article?.title || "Blog MedRent"}
  description={article?.shortDescription || "Artículo de MedRent sobre tecnología médica e innovación clínica."}
  keywords={`${article?.title || "blog"}; tecnología médica; MedRent`}
  ogType="article"
  pageType="blog"
  ogImage={heroImageUrl}
>
  <Fragment slot="head">
    <BreadcrumbSchema
      id={breadcrumbId}
      items={[
        { name: "Inicio", url: `${baseUrl}/` },
        { name: "Blog", url: `${baseUrl}/blog` },
        { name: article?.title || "Artículo", url: canonicalUrl },
      ]}
    />
    <script type="application/ld+json" set:html={
      JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "WebPage",
            "@id": `${canonicalUrl}#webpage`,
            url: canonicalUrl,
            name: article?.title || "Blog MedRent",
            description:
              article?.shortDescription ||
              "Artículo de MedRent sobre tecnología médica e innovación clínica.",
            isPartOf: { "@id": `${baseUrl}/#website` },
            about: { "@id": `${baseUrl}/#organization` },
            inLanguage: "es-MX",
            breadcrumb: { "@id": breadcrumbId },
            mainEntity: { "@id": postId },
            primaryImageOfPage: {
              "@type": "ImageObject",
              url: heroImageUrl,
            },
          },
          {
            "@type": "Person",
            "@id": personId,
            name: article?.writer?.fullName || "Autor",
            description: article?.writer?.shortDescription,
            image: article?.writer?.avatar?.url
              ? {
                  "@type": "ImageObject",
                  url: article?.writer?.avatar?.url,
                }
              : undefined,
            url: `${baseUrl}/blog/autor/${authorSlug}`,
            worksFor: { "@id": `${baseUrl}/#organization` },
          },
          {
            "@type": "BlogPosting",
            "@id": postId,
            mainEntityOfPage: { "@id": `${canonicalUrl}#webpage` },
            headline: article?.title || "Blog MedRent",
            description:
              article?.shortDescription ||
              "Artículo de MedRent sobre tecnología médica e innovación clínica.",
            image: heroImageUrl ? [heroImageUrl] : undefined,
            datePublished: article?.createdAt,
            dateModified: article?.createdAt,
            author: { "@id": personId },
            publisher: { "@id": `${baseUrl}/#organization` },
            inLanguage: "es-MX",
          },
        ],
      })
    }></script>
  </Fragment>

  <Fragment slot="metas">
    <!-- <meta id="description" content={pageDescription}>
    <meta property="og:title" content={pageTitle}>
    <meta property="og:description" content={pageDescription}>
    <meta property="og:type" content="article">
    <meta property="og:image" content={articulo?.ImagenHeroArticulo?.url ? buildImageUrl(articulo.ImagenHeroArticulo.url) : "/images/og/default.jpg"}>
    <meta id="twitter:card" content="summary_large_image">
    <meta id="twitter:title" content={pageTitle}>
    <meta id="twitter:description" content={pageDescription}>
    <meta id="twitter:image" content={articulo?.ImagenHeroArticulo?.url ? buildImageUrl(articulo.ImagenHeroArticulo.url) : "/images/og/default.jpg"}> -->
  </Fragment>

  <main class="max-w-7xl mx-auto">
    <div class="w-full">
      <div class="mx-auto max-w-7xl px-4 py-3 md:px-6">
        <Breadcrumb
          surface="light"
          navPosition="inline"
          textColor="text-dark"
          class="max-w-none! px-0!"
          items={[
            { name: "INICIO", href: "/" },
            { name: "BLOG", href: "/blog" },
            { name: "ARTÍCULO" },
          ]}
        />
      </div>
    </div>

    <!-- Cabecera -->
    <div class="w-full p-4 md:py-6 md:px-4">
      {classificationLabel && (
        <p class="mb-4 uppercase font-lato text-[14px] font-medium leading-5 tracking-[0.1px] text-[#006764]">
          {classificationLabel}
        </p>
      )}

      <h1 class="blog-article-hero-title">
        {article?.title}
      </h1>

      {article?.shortDescription && (
        <p class="font-lato text-base font-normal leading-6 tracking-[0.5px] text-on-surface-variant">
          {article.shortDescription}
        </p>
      )}

      <div class="my-6 flex w-full flex-col">
        <p
          class="w-full self-stretch font-lato text-xs font-medium italic leading-4 tracking-[0.5px] text-on-surface-variant"
        >
          {formatDate(article?.createdAt)}
        </p>
      </div>
    </div>

    {article?.heroImage?.url && (
      <img
        src={article.heroImage.url}
        alt={article.heroImage.alternativeText || 'Imagen del artículo'}
        class="w-full h-auto rounded mb-6"
      />
    )} 
    
    <SocialMedia articulo={article} inline={true} class="px-4" clase="SocialMediaMobile" />

    <div class="grid grid-cols-1 gap-4 lg:grid-cols-12 lg:gap-6">
      <!-- Columna principal: Contenido del artículo -->
      <div class="lg:col-span-8 dinamicContent p-4 md:py-6 md:px-4 contentBlog">
        {Array.isArray(article?.content)
          ? article.content.map((item: any) => {
              switch (item?.__component) {
                case 'blog.article-content': {
                  const blocks = Array.isArray(item.articleContent)
                    ? item.articleContent
                    : [item.articleContent];
                  return <BlocksRenderer content={blocks} />;
                }
                case 'blog.article-image': {
                  return item.articleImage?.url ? (
                    <img
                      src={item.articleImage.url}
                      alt={item.articleImage.alternativeText || 'Imagen del artículo'}
                      class="w-full h-auto rounded mb-6"
                    />
                  ) : null;
                }
                case 'blog.article-quote': {
                  return (
                    <div class="citaBlog">
                      <p>"{item.quoteText}"</p>
                      {item.authorName && (
                        <div class="citaBlogAuthor">
                          <span>- {item.authorName}</span>
                        </div>
                      )}
                    </div>
                  );
                }
                default:
                  return null;
              }
            })
          : <p>No hay contenido disponible</p>
        }
        
        <section class="acreditadoPor flex items-center gap-4 p-4 pt-6" style="border-top: 0.5px dashed var(--color-gray-dark);">
          {article?.writer?.avatar?.url && (
            <img
              src={article.writer.avatar.url}
              alt={article.writer.fullName || 'Autor'}
              class="w-20 h-20 rounded-full object-cover"
            />
          )}
          <div class="flex flex-col justify-center items-start gap-1">
            <span class="text-[var(--color-primary)] font-lato text-xs font-medium leading-4 tracking-wide">
              ACREDITADO POR:
            </span>
            <div class="flex items-center gap-2 mt-1 flex-wrap">
              <a 
                href={`/blog/autor/${article?.writer?.slug || 'team-medrent'}`}
                class="text-[#261819] font-lato text-base font-bold leading-6 tracking-[0.15px] hover:underline decoration-[var(--color-primary)]"
              >
                {article?.writer?.fullName || 'Backoffice | Team Medrent'}
              </a>
              <span class="text-on-surface-variant font-medium italic">
                {" — "}
                {authorArticleTotal}{" "}
                {authorArticleTotal === 1 ? "artículo" : "artículos"}
              </span>
            </div>
            <span class="text-[var(--color-green-dark)] font-lato text-sm font-normal leading-5 tracking-wide">
              {article?.writer?.shortDescription}
            </span>
          </div>
        </section>
      </div>

      <!-- Relacionados: solo tablet/móvil (desktop en aside); mismo listado por clasificación -->
      <div class="col-span-full lg:hidden px-4 md:px-6">
        <ArticleRelatedMobile
          articulos={articulosRelacionados}
          tagByArticleKey={classificationTagByArticleKey}
        />
      </div>

      <!-- Columna lateral: Otros artículos, suscripción y ver más -->
      <aside class="lg:col-span-4 flex flex-col gap-6 pt-4 pr-4 contentBlogAside">
        <!-- Botones de redes sociales -->
        <SocialMedia articulo={article} inline={false} class="px-4" clase="SocialMediaDesktop" />

        <section class="flex-col gap-2 flex max-w-7xl mx-auto mb-6">
          <h2 class="text-lg font-bold text-[#261819] blogSubtitle">Suscríbete al blog</h2>
          <p class="text-[14px] text-[var(--color-primary)] max-w-xl mx-auto m-0">
            Recibe en tu correo las últimas novedades en tecnología médica, consejos especializados y actualizaciones exclusivas sobre nuestras soluciones.
          </p>
          <form class="justify-center max-w-xl w-full mx-auto flex flex-col gap-4 pt-4">
            <div class="relative w-full flex">
              <label for="email" class="absolute -top-2 left-3 bg-[#3D4948] text-[#FFF] text-xs px-1 rounded-sm">Correo electrónico*</label>
              <input id="email" type="email" placeholder="Ej: nombre@correo.com" class="w-full border border-[#3b2a2a] rounded-l-md py-2 px-4 placeholder-gray-400 focus:outline-none focus:ring-1 focus:ring-[#8C0032] bg-white" required="" />
              <button type="submit" class="bg-[#006764] text-white font-semibold py-2 px-6 rounded-r-md transition-colors duration-300 cursor-pointer">
                Suscríbeme
              </button>
            </div>
            <div class="flex items-center justify-start w-full gap-2 text-sm text-[#3b2a2a]">
              <input type="checkbox" id="privacy" class="w-4 h-4 accent-[#2c1b1b]" required="" />
              <label for="privacy" class="cursor-pointer">He leído y acepto el
                <a href="/aviso-de-privacidad" class="underline text-[var(--color-primary)]"> Aviso de Privacidad</a>
              </label>
            </div>
          </form>
        </section>

        <section class="articulosRelacionadosDesktop flex flex-col gap-6 mb-6">
          <h2 class="blog-aside-section-title">Relacionados</h2>
          <div class="flex flex-col gap-4 md:gap-4" style="gap:16px;">
            {Array.isArray(articulosRelacionados) && articulosRelacionados.length > 0 ? (
              articulosRelacionados.slice(0, 3).map((rel) => (
                <div class="bg-white rounded-[16px] p-4 flex items-start gap-4 hover:bg-[var(--color-secondary-light)] min-h-[220px]" style="padding:16px; gap:16px;">
                  <div class="flex-shrink-0 w-20 h-20 rounded-[8px] overflow-hidden bg-[#F8E6EA] flex items-center justify-center">
                    {rel.heroImage?.url ? (
                      <img src={rel.heroImage.url} alt={rel.heroImage.alternativeText || 'Imagen del artículo'} class="object-cover w-20 h-20 rounded-[8px]" />
                    ) : null}
                  </div>
                  <div class="flex flex-col h-full justify-between w-full">
                    <div>
                      {getClassificationTag(rel, classificationTagByArticleKey) && (
                        <span class="mb-1 block uppercase font-lato text-[14px] font-medium leading-5 tracking-[0.1px] text-[#006764]">
                          {getClassificationTag(rel, classificationTagByArticleKey)}
                        </span>
                      )}
                      <a href={`/blog/${rel.slug}`}>
                        <h3 class="blog-related-card-title mb-1 cursor-pointer line-clamp-2">
                          {rel.title}
                        </h3>
                      </a>
                      <p class="blog-related-card-excerpt mb-1 line-clamp-3">{rel.shortDescription}</p>
                    </div>
                    <div class="mt-2 flex flex-wrap items-baseline gap-x-1 font-lato text-xs leading-4">
                      <span class="text-on-surface-variant">Por:</span>
                      <a
                        href={`/blog/autor/${rel.writer?.slug}`}
                        class="text-[var(--color-primary)] underline decoration-[var(--color-primary)]"
                      >
                        {rel.writer?.fullName || "Medrent"}
                      </a>
                      <span class="text-on-surface-variant">• {formatDate(rel.createdAt)}</span>
                    </div>
                  </div>
                </div>
              ))
            ) : (
              <p class="text-on-surface-variant font-lato text-sm">Por el momento no hay artículos relacionados.</p>
            )}
          </div>

          <!-- {Array.isArray(articulosRelacionados) && articulosRelacionados.length > 0 ? (
            <a href="/blog" class="flex w-full justify-center cursor-pointer items-center gap-2 self-stretch rounded-[4px] border border-[#261819] text-black text-[14px] font-bold font-lato transition-colors hover:bg-black hover:text-white group" style="padding:14px 16px;">
              Ver más artículos
              <svg xmlns="http://www.w3.org/2000/svg" width="12" height="13" viewBox="0 0 12 13" fill="none">
                <path d="M11.92 5.62409C11.8724 5.50134 11.801 5.3892 11.71 5.29409L6.71 0.294092C6.61676 0.200853 6.50607 0.126893 6.38425 0.0764322C6.26243 0.0259719 6.13186 0 6 0C5.7337 0 5.4783 0.105788 5.29 0.294092C5.19676 0.38733 5.1228 0.498021 5.07234 0.619843C5.02188 0.741665 4.99591 0.872233 4.99591 1.00409C4.99591 1.27039 5.1017 1.52579 5.29 1.71409L8.59 5.00409H1C0.734784 5.00409 0.48043 5.10945 0.292893 5.29699C0.105357 5.48452 0 5.73888 0 6.00409C0 6.26931 0.105357 6.52366 0.292893 6.7112C0.48043 6.89873 0.734784 7.00409 1 7.00409H8.59L5.29 10.2941C5.19627 10.3871 5.12188 10.4977 5.07111 10.6195C5.02034 10.7414 4.9942 10.8721 4.9942 11.0041C4.9942 11.1361 5.02034 11.2668 5.07111 11.3887C5.12188 11.5105 5.19627 11.6211 5.29 11.7141C5.38296 11.8078 5.49356 11.8822 5.61542 11.933C5.73728 11.9838 5.86799 12.0099 6 12.0099C6.13201 12.0099 6.26272 11.9838 6.38458 11.933C6.50644 11.8822 6.61704 11.8078 6.71 11.7141L11.71 6.71409C11.801 6.61899 11.8724 6.50684 11.92 6.38409C12.02 6.14063 12.02 5.86755 11.92 5.62409Z" fill="#261819" class="transition-colors group-hover:fill-white"/>
              </svg>
            </a>
          ) : null} -->
        </section>
      </aside>
    </div>

    <!-- <section class="max-w-7xl mx-auto py-8 sliderArticulosRelacionados px-4 md:px-6 lg:hidden">
      <h2 class="text-lg font-bold text-[#261819] blogSubtitle mb-6">RELACIONADOS</h2> -->
      <!-- <SlideArticulos articulos={articulosRelacionados} /> -->
    <!-- </section> -->
  </main>

  <!-- Ancho completo del #contenido-principal, pegado al bloque previo y al footer -->
  <Newsletter />
</Layout>
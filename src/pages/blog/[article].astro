---
import Layout from '@layouts/Layout.astro';
import { strapiFetch } from "@server/strapiClient";
import { formatDate, buildImageUrl } from '@lib/utils.js';
import SocialMedia from '@components/blog/SocialMedia.astro';
// import SlideArticulos from '@components/blog/SlideArticulos.astro';
import Newsletter from '@components/FormNewsletter.astro';
import { BlocksRenderer } from '@strapi/blocks-react-renderer';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';

export async function getStaticPaths() {
  const articles = await strapiFetch(
    "/blog-articles?sort=publishedAt:desc&populate[heroImage]=true&populate[writer][populate][avatar]=true&populate[content][populate]=*",
  );

  return articles.data.map((page) => ({
    params: { article: page.slug },
    props: {
      article: page,
    },
  }));
}

const { article } = Astro.props as { article: any };

const baseUrl = Astro.site ? new URL(Astro.site).origin : "https://www.medrent.mx";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const breadcrumbId = `${canonicalUrl}#breadcrumb`;
const logoUrl = `${baseUrl}/favicon-512.png`;
const heroImageUrl = article?.heroImage?.url || logoUrl;
const authorSlug = article?.writer?.slug || 'team-medrent';
const personId = `${baseUrl}/blog/autor/${authorSlug}#person`;
const postId = `${canonicalUrl}#post`;

// Obtener artículos relacionados (excluyendo el actual)
let articulosRelacionados = [];
try {
  // Aquí puedes personalizar la lógica de relacionados
  // Por ejemplo, por misma subcategoría o tag
  const filterParams = new URLSearchParams({
    'populate': '*',
    'sort': 'publishedAt:desc',
    'pagination[limit]': '10',
    'filters[slug][$ne]': article.slug, // Excluir el artículo actual
  });

  // Si tiene subcategoría, filtrar por ella
  if (article?.subcategory?.slug) {
    filterParams.append('filters[subcategory][slug][$eq]', article.subcategory.slug);
  }

  const relatedResponse = await strapiFetch(`/blog-articles?${filterParams.toString()}`);
  articulosRelacionados = relatedResponse.data || [];
} catch (error) {
  console.error('Error fetching related articles:', error);
  articulosRelacionados = [];
}
---

<Layout
  title={article?.title || "Blog MedRent"}
  description={article?.shortDescription || "Artículo de MedRent sobre tecnología médica e innovación clínica."}
  keywords={`${article?.title || "blog"}; tecnología médica; MedRent`}
  ogType="article"
  pageType="blog"
  ogImage={heroImageUrl}
>
  <Fragment slot="head">
    <BreadcrumbSchema
      id={breadcrumbId}
      items={[
        { name: "Inicio", url: `${baseUrl}/` },
        { name: "Blog", url: `${baseUrl}/blog` },
        { name: article?.title || "Artículo", url: canonicalUrl },
      ]}
    />
    <script type="application/ld+json" set:html={
      JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "WebPage",
            "@id": `${canonicalUrl}#webpage`,
            url: canonicalUrl,
            name: article?.title || "Blog MedRent",
            description:
              article?.shortDescription ||
              "Artículo de MedRent sobre tecnología médica e innovación clínica.",
            isPartOf: { "@id": `${baseUrl}/#website` },
            about: { "@id": `${baseUrl}/#organization` },
            inLanguage: "es-MX",
            breadcrumb: { "@id": breadcrumbId },
            mainEntity: { "@id": postId },
            primaryImageOfPage: {
              "@type": "ImageObject",
              url: heroImageUrl,
            },
          },
          {
            "@type": "Person",
            "@id": personId,
            name: article?.writer?.fullName || "Autor",
            description: article?.writer?.shortDescription,
            image: article?.writer?.avatar?.url
              ? {
                  "@type": "ImageObject",
                  url: article?.writer?.avatar?.url,
                }
              : undefined,
            url: `${baseUrl}/blog/autor/${authorSlug}`,
            worksFor: { "@id": `${baseUrl}/#organization` },
          },
          {
            "@type": "BlogPosting",
            "@id": postId,
            mainEntityOfPage: { "@id": `${canonicalUrl}#webpage` },
            headline: article?.title || "Blog MedRent",
            description:
              article?.shortDescription ||
              "Artículo de MedRent sobre tecnología médica e innovación clínica.",
            image: heroImageUrl ? [heroImageUrl] : undefined,
            datePublished: article?.createdAt,
            dateModified: article?.createdAt,
            author: { "@id": personId },
            publisher: { "@id": `${baseUrl}/#organization` },
            inLanguage: "es-MX",
          },
        ],
      })
    }></script>
  </Fragment>

  <Fragment slot="metas">
    <!-- <meta id="description" content={pageDescription}>
    <meta property="og:title" content={pageTitle}>
    <meta property="og:description" content={pageDescription}>
    <meta property="og:type" content="article">
    <meta property="og:image" content={articulo?.ImagenHeroArticulo?.url ? buildImageUrl(articulo.ImagenHeroArticulo.url) : "/images/og/default.jpg"}>
    <meta id="twitter:card" content="summary_large_image">
    <meta id="twitter:title" content={pageTitle}>
    <meta id="twitter:description" content={pageDescription}>
    <meta id="twitter:image" content={articulo?.ImagenHeroArticulo?.url ? buildImageUrl(articulo.ImagenHeroArticulo.url) : "/images/og/default.jpg"}> -->
  </Fragment>

  <main class="max-w-7xl mx-auto">
    <!-- Cabecera -->
    <div class="w-full p-4 md:py-6 md:px-4">
      {article?.subcategory?.name && (
        <p class="text-[var(--color-primary)] text-[12px] font-lato uppercase">
          {article.subcategory.name}
        </p>
      )}

      <h1 class="font-light text-[32px] text-[#261819] font-lato">
        {article?.title}
      </h1>
      
      {article?.shortDescription && (
        <p class="text-[var(--color-primary)] text-[16px] font-normal">
          {article.shortDescription}
        </p>
      )}

      <div class="w-full my-6">
        <p class="text-[var(--color-primary)] text-sm font-normal italic">
          • {formatDate(article?.createdAt)}
        </p>
      </div>
    </div>

    {article?.heroImage?.url && (
      <img
        src={article.heroImage.url}
        alt={article.heroImage.alternativeText || 'Imagen del artículo'}
        class="w-full h-auto rounded mb-6"
      />
    )} 
    
    <SocialMedia articulo={article} inline={true} class="px-4" clase="SocialMediaMobile" />

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
      <!-- Columna principal: Contenido del artículo -->
      <div class="lg:col-span-8 dinamicContent p-4 md:py-6 md:px-4 contentBlog">
          <div class="w-full py-4">
            <h2 class="font-light text-[32px] text-[#171D1C] font-lato">
              Antecedentes
            </h2>
          </div>



        {Array.isArray(article?.content)
          ? article.content.map((item) => {
              switch (item?.__component) {
                case 'blog.article-content': {
                  const blocks = Array.isArray(item.articleContent)
                    ? item.articleContent
                    : [item.articleContent];
                  return <BlocksRenderer content={blocks} />;
                }
                case 'blog.article-image': {
                  return item.articleImage?.url ? (
                    <img
                      src={item.articleImage.url}
                      alt={item.articleImage.alternativeText || 'Imagen del artículo'}
                      class="w-full h-auto rounded mb-6"
                    />
                  ) : null;
                }
                case 'blog.article-quote': {
                  return (
                    <div class="citaBlog">
                      <p>"{item.quoteText}"</p>
                      {item.authorName && (
                        <div class="citaBlogAuthor">
                          <span>- {item.authorName}</span>
                        </div>
                      )}
                    </div>
                  );
                }
                default:
                  return null;
              }
            })
          : <p>No hay contenido disponible</p>
        }
        
        <section class="acreditadoPor flex items-center gap-4 p-4 pt-6" style="border-top: 0.5px dashed var(--color-gray-dark);">
          {article?.writer?.avatar?.url && (
            <img
              src={article.writer.avatar.url}
              alt={article.writer.fullName || 'Autor'}
              class="w-20 h-20 rounded-full object-cover"
            />
          )}
          <div class="flex flex-col justify-center items-start gap-1">
            <span class="text-[var(--color-primary)] font-lato text-xs font-medium leading-4 tracking-wide">
              ACREDITADO POR:
            </span>
            <div class="flex items-center gap-2 mt-1 flex-wrap">
              <a 
                href={`/blog/autor/${article?.writer?.slug || 'team-medrent'}`}
                class="text-[#261819] font-lato text-base font-bold leading-6 tracking-[0.15px] hover:underline decoration-[var(--color-primary)]"
              >
                {article?.writer?.fullName || 'Backoffice | Team Medrent'}
              </a>
              <span class="text-on-surface-variant font-medium italic">
                {" — "}{Array.isArray(articulosRelacionados) ? articulosRelacionados.length + 1 : 1} Artículo{Array.isArray(articulosRelacionados) && articulosRelacionados.length + 1 !== 1 ? 's' : ''}
              </span>
            </div>
            <span class="text-[var(--color-green-dark)] font-lato text-sm font-normal leading-5 tracking-wide">
              {article?.writer?.shortDescription}
            </span>
          </div>
        </section>
      </div>

      <!-- Columna lateral: Otros artículos, suscripción y ver más -->
      <aside class="lg:col-span-4 flex flex-col gap-6 pt-4 pr-4 contentBlogAside">
        <!-- Botones de redes sociales -->
        <SocialMedia articulo={article} inline={false} class="px-4" clase="SocialMediaDesktop" />

        <section class="flex-col gap-2 flex max-w-7xl mx-auto mb-6"> 
          <h2 class="text-lg font-bold text-[#261819] blogSubtitle">Suscríbete al blog</h2>
          <p class="text-[14px] text-[var(--color-primary)] max-w-xl mx-auto m-0">
            Recibe en tu correo las últimas novedades en tecnología médica, consejos especializados y actualizaciones exclusivas sobre nuestras soluciones.
          </p> 
          <form class="justify-center max-w-xl w-full mx-auto flex flex-col gap-4 pt-4"> 
            <div class="relative w-full flex"> 
              <label for="email" class="absolute -top-2 left-3 bg-[#3D4948] text-[#FFF] text-xs px-1 rounded-sm">Correo electrónico*</label> 
              <input id="email" type="email" placeholder="Ej: nombre@correo.com" class="w-full border border-[#3b2a2a] rounded-l-md py-2 px-4 placeholder-gray-400 focus:outline-none focus:ring-1 focus:ring-[#8C0032] bg-white" required=""> 
              <button type="submit" class="bg-[#006764] text-white font-semibold py-2 px-6 rounded-r-md transition-colors duration-300 cursor-pointer">
                Suscríbeme
              </button> 
            </div>
            <div class="flex items-center justify-start w-full gap-2 text-sm text-[#3b2a2a]"> 
              <input type="checkbox" id="privacy" class="w-4 h-4 accent-[#2c1b1b]" required=""> 
              <label for="privacy" class="cursor-pointer">He leído y acepto el 
                <a href="/aviso-de-privacidad" class="underline text-[#text-[var(--color-primary)]]"> Aviso de Privacidad</a> 
              </label> 
            </div> 
          </form> 
        </section>

        <section class="articulosRelacionadosDesktop flex gap-6 flex-col gap-6 mb-6">
          <h2 class="text-lg font-bold text-[#261819] blogSubtitle">RELACIONADOS</h2>
          <div class="flex flex-col gap-4 md:gap-4" style="gap:16px;">
            {Array.isArray(articulosRelacionados) && articulosRelacionados.length > 0 ? (
              articulosRelacionados.slice(0, 3).map((rel) => (
                <div class="bg-white rounded-[16px] p-4 flex items-start gap-4 hover:bg-[var(--color-secondary-light)] min-h-[220px]" style="padding:16px; gap:16px;">
                  <div class="flex-shrink-0 w-20 h-20 rounded-[8px] overflow-hidden bg-[#F8E6EA] flex items-center justify-center">
                    {rel.heroImage?.url ? (
                      <img src={rel.heroImage.url} alt={rel.heroImage.alternativeText || 'Imagen del artículo'} class="object-cover w-20 h-20 rounded-[8px]" />
                    ) : null}
                  </div>
                  <div class="flex flex-col h-full justify-between w-full">
                    <div>
                      <span class="mb-1 text-[11px] font-normal font-medium text-[#text-[var(--color-primary)]] font-lato uppercase" style="font-size:11px;font-style:normal;font-weight:500;">
                        {rel.subcategory?.name || ''}
                      </span>
                      <a href={`/blog/${rel.slug}`}>
                        <h3 class="mb-1 text-[16px] font-bold text-[#261819] hover:text-[var(--color-primary)] hover:underline decoration-[var(--color-primary)] not-italic font-lato cursor-pointer line-clamp-2">
                          {rel.title}
                        </h3>
                      </a>
                      <p class="mb-1 text-[14px] text-[var(--color-primary)] line-clamp-3">{rel.shortDescription}</p>
                    </div>
                    <div class="flex">
                      <span class="block text-xs text-[#261819] font-lato mt-2">Por: &nbsp;</span>
                      <a href={`/blog/autor/${rel.writer?.slug}`} class="block text-xs text-[#text-[var(--color-primary)]] underline decoration-[#text-[var(--color-primary)]] cursor-pointer font-lato mt-2">
                        {rel.writer?.fullName || 'Medrent'}
                      </a>
                      <span class="block text-xs text-[var(--color-primary)] font-lato mt-2">
                        &nbsp;• {formatDate(rel.createdAt)}
                      </span>
                    </div>
                  </div>
                </div>
              ))
            ) : (
              <p class="text-[var(--color-primary)]]">Por el momento no hay artículos relacionados.</p>
            )}
          </div>


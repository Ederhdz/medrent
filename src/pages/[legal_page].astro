---
import Layout from "@layouts/Layout.astro";
import { strapiFetch } from "@server/strapiClient";
import { BlocksRenderer } from '@strapi/blocks-react-renderer';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import Breadcrumb from '@components/navigation/Breadcrumb.astro';

export async function getStaticPaths() {
  const res = await strapiFetch("/legal-content?populate[legalPages][populate]=imageHero");
  const mainPublishedAt = res.data.publishedAt;
  
  return res.data.legalPages.map((page: any) => ({
    params: { legal_page: page.slug },
    props: { 
      pageData: page,
      mainPublishedAt: mainPublishedAt
    }
  }));
}

const { pageData, mainPublishedAt } = Astro.props as any;

const pageDataSafe: any = pageData || {};
const title = pageDataSafe.title;
const content = pageDataSafe.content;
const imageHero = pageDataSafe.imageHero;
const pageSlug = pageDataSafe.slug ?? "";

const baseUrl = Astro.site ? new URL(Astro.site).origin : "https://www.medrent.mx";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const breadcrumbId = `${canonicalUrl}#breadcrumb`;
const logoUrl = `${baseUrl}/favicon-512.png`;
const heroImageUrl = imageHero?.url || logoUrl;
const isPrivacy = pageSlug === "aviso-de-privacidad";
const schemaType = isPrivacy ? "PrivacyPolicy" : "TermsOfService";
const pageDescription =
  title === "Aviso de privacidad"
    ? "Consulta el aviso de privacidad y el tratamiento de datos personales de MedRent."
    : title === "Condiciones de uso"
      ? "Revisa las políticas de uso del sitio web y plataformas digitales de MedRent."
      : undefined;

//console.log('pageData:', JSON.stringify(pageData, null, 2));
---

<Layout
  title={title}
  description={title === "Aviso de privacidad"
    ? "Consulta el aviso de privacidad y el tratamiento de datos personales de MedRent."
    : title === "Condiciones de uso"
      ? "Revisa las políticas de uso del sitio web y plataformas digitales de MedRent."
      : undefined}
  keywords={title === "Aviso de privacidad"
    ? "aviso de privacidad; datos personales; MedRent"
    : title === "Condiciones de uso"
      ? "condiciones de uso; cookies; políticas sitio web; MedRent"
      : undefined}
  robots={["aviso-de-privacidad", "condiciones-de-uso"].includes(pageSlug) ? "noindex,follow" : "index,follow"}
  ogImage={heroImageUrl}
>
  <Fragment slot="head">
    <BreadcrumbSchema
      items={[
        { name: 'Inicio', url: `${baseUrl}/` },
        { name: title, url: canonicalUrl },
      ]}
      id={breadcrumbId}
    />
    <script type="application/ld+json" set:html={
      JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": ["WebPage", schemaType],
            "@id": `${canonicalUrl}#webpage`,
            url: canonicalUrl,
            name: title,
            description: pageDescription,
            isPartOf: { "@id": `${baseUrl}/#website` },
            about: { "@id": `${baseUrl}/#organization` },
            inLanguage: "es-MX",
            breadcrumb: { "@id": breadcrumbId },
            primaryImageOfPage: heroImageUrl
              ? { "@type": "ImageObject", url: heroImageUrl }
              : undefined,
          },
        ],
      })
    }></script>
  </Fragment>

  <div class="absolute w-full z-2">
    <Breadcrumb
      textColor="#171D1C"
      items={[
        { name: "INICIO", href: "/" },
        { name: title }
      ]}
    />
  </div>
  <section class="w-full relative bg-[#F5FAF9]">
    <div class="w-full">
      {imageHero && (
        <img 
          src={imageHero.url} 
          alt={title} 
          class="w-full h-[300px] object-cover"
        />
      )}
      
      <div class="absolute inset-0"></div>

      <div class="absolute inset-0 flex items-center justify-center">
        <div class="text-center text-[#171D1C]">
          <h1 class="font-lato font-normal text-[28px] md:text-[32px]">
            {title}
          </h1>
          <p class="mt-2 text-[#3D4948] font-lato text-sm">
            Última actualización: {mainPublishedAt ? new Date(mainPublishedAt).toLocaleDateString('es-MX', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            }) : 'Fecha no disponible'}
          </p>
        </div>
      </div>
    </div>
</section>

  <section class="max-w-7xl mx-auto px-4 py-12 text-[#261819] font-lato space-y-6 text-sm md:text-base leading-relaxed">
    <div>
      {content ? (
        <BlocksRenderer content={content} />
      ) : (
        <p>Cargando contenido...</p> 
      )}
    </div>
  </section>
</Layout>
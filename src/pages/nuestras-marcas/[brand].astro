---
import { getBrands } from "@server/api/brands";
import { getProducts } from "@server/api/products";
import Layout from "@layouts/Layout.astro";
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import Breadcrumb from '@components/navigation/Breadcrumb.astro';
import ProductGrid from "@components/product/ProductGrid.astro";
import PLPLayout from "@components/product/PLPLayout.astro";

export async function getStaticPaths() {
  const brands = await getBrands();
  console.log("Brands:", brands); // Agrega este log para verificar los datos de las marcas
  
  return brands.map((brand:any) => ({
    params: { brand: brand.slug },
  }));
}

const { brand } = Astro.params;
const products = await getProducts({ brand });
console.log("Products for brand:", products); // Agrega este log para verificar los productos obtenidos
---


 <Layout title="Productos">
    <Fragment slot="head">
      <BreadcrumbSchema
      items={[
          { name: 'Inicio', url: 'https://www.medrent.mx' },
          { name: 'Nuestras Marcas', url: 'https://www.medrent.mx/nuestras-marcas' },
      ]}
      />
    </Fragment>


  <section class="relative w-full h-[140px] max-w-7xl mx-auto overflow-hidden">    
      <div class="absolute inset-0 heroproductos">
          <Breadcrumb
          textColor="text-white"
          items={[
              { name: "INICIO", href: "/" },
              { name: "NUESTRAS MARCAS", href: "/nuestras-marcas" },
              { name: brand.toUpperCase() }
          ]}
      />
          <img src="/temp/HeroPLP.png" alt="Todos los productos" class="w-full h-full object-cover rounded-b-[24px]" />
      </div>
  </section>

  <PLPLayout title={`Marca ${brand}`}>
    <ProductGrid products={products} />
  </PLPLayout>
</Layout>
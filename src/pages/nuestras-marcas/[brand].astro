---
import { getProducts } from "@server/api/products";

export async function getStaticPaths() {
  // Necesitamos lista de marcas
  const brands = await getBrands();

  console.log("Brands for static paths:", brands);

  return brands.map((brand) => ({
    params: { brand: brand.slug },
  }));
}

import { getBrands } from "@server/api/brands";

const { brand } = Astro.params;

const products = await getProducts({ brand });
---

<section class="max-w-7xl mx-auto px-4 py-12">
  <h1 class="text-3xl font-semibold mb-8">
    Productos de {brand}
  </h1>

  {products.length === 0 ? (
    <p>No products found.</p>
  ) : (
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {products.map((product) => (
        <a
          href={`/productos/${product.slug}`}
          class="border rounded-lg p-4 hover:shadow-md transition"
        >
          {product.coverImage && (
            <img
              src={product.coverImage}
              alt={product.name}
              class="mb-4 h-40 w-full object-contain"
            />
          )}
          <h2 class="font-medium">{product.name}</h2>
        </a>
      ))}
    </div>
  )}
</section>

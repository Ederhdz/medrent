---
import "../styles/global.css"; 
import "lenis/dist/lenis.css";
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const {
  title,
  description,
  keywords,
  robots = "index,follow",
  ogTitle,
  ogDescription,
  ogType = "website",
  ogUrl,
  ogImage,
  ogSiteName = "MedRent",
  ogLocale = "es_MX",
  twitterCard = "summary_large_image",
  twitterSite = "@MedRent_MX",
  twitterTitle,
  twitterDescription,
  twitterImage,
} = Astro.props;
const siteOrigin = Astro.url?.origin ?? (Astro.site ? new URL(Astro.site).origin : "https://www.medrent.mx");
const resolvedTitle = title ?? "MedRent México | Tecnología médica y financiamiento sin enganche";
const resolvedDescription =
  description ??
  "Equipos médicos para neurodiagnóstico, neuromodulación, rehabilitación y ultrasonido con soporte y asesoría. Agenda tu demo.";
const resolvedOgTitle = ogTitle ?? resolvedTitle;
const resolvedOgDescription = ogDescription ?? resolvedDescription;
const resolvedOgUrl = ogUrl ?? canonical;
const resolvedOgImage = ogImage ?? `${siteOrigin}/favicon-512.png`;
const resolvedTwitterTitle = twitterTitle ?? resolvedOgTitle;
const resolvedTwitterDescription = twitterDescription ?? resolvedOgDescription;
const resolvedTwitterImage = twitterImage ?? resolvedOgImage;
const isLocalEnv = Astro.url.hostname === "localhost" || Astro.url.hostname === "127.0.0.1";

import { SITE } from '@lib/site';
const site = SITE;

import OrganizationSchema from '@components/seo/OrganizationSchema.astro';
import WebSiteSchema from '@components/seo/WebSiteSchema.astro';

import Upperbar from "@components/layout/header/Upperbar.astro";
import Footer from "@components/layout/footer/Footer.astro";
import Navbar from "@components/layout/header/Navbar.astro";
import StickyCta from "@components/layout/overlays/StickyCta.astro";
---

<!doctype html>
<html lang="es-MX">
  <head>
    <!-- 1. Meta esenciales -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="google-site-verification" content="bfDcp6cDny991Jfo6sn0-XdBnk7ZsE_uMlqxZuBNDBY" />

    <!-- 2. Title -->
    <title>{resolvedTitle}</title>

    <!-- 3. Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- 4. Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="preload" href="/fonts/Lato-Regular.ttf" as="font" type="font/ttf" crossorigin>
    <link rel="preload" href="/fonts/Lato-Bold.ttf" as="font" type="font/ttf" crossorigin>
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
    {!isLocalEnv && <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin>}
    <link rel="dns-prefetch" href="//media.strapiapp.com">

    <!-- 5. Metas dinámicos (OG, description, etc.) -->
    <meta name="description" content={resolvedDescription} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="robots" content={robots} />

    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={resolvedOgUrl} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:site_name" content={ogSiteName} />
    <meta property="og:locale" content={ogLocale} />

    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:site" content={twitterSite} />
    <meta name="twitter:title" content={resolvedTwitterTitle} />
    <meta name="twitter:description" content={resolvedTwitterDescription} />
    <meta name="twitter:image" content={resolvedTwitterImage} />
    <slot name="metas" /> 

    <!-- 6. Schemas globales -->
    <OrganizationSchema />
    <WebSiteSchema />

    <!-- 7. Schemas por página (Breadcrumb, etc.) -->
    <slot name="head" />

    <!-- 8. CSS externo -->
      <!-- Required Core stylesheet | https://github.com/glidejs/glide -->
    <link
      rel="preload"
      as="style"
      href="https://cdn.jsdelivr.net/npm/@glidejs/glide/dist/css/glide.core.min.css"
      onload="this.onload=null;this.rel='stylesheet'"
    >
    <noscript>
      <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@glidejs/glide/dist/css/glide.core.min.css">
    </noscript>
      <!-- Optional Theme stylesheet | https://github.com/glidejs/glide/dist/css/glide.theme.min.css -->
    <link
      rel="preload"
      as="style"
      href="https://cdn.jsdelivr.net/npm/@glidejs/glide/dist/css/glide.theme.min.css"
      onload="this.onload=null;this.rel='stylesheet'"
    >
    <noscript>
      <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@glidejs/glide/dist/css/glide.theme.min.css">
    </noscript>
    <link
      rel="preload"
      as="style"
      href="https://cdn.jsdelivr.net/npm/glider-js@1/glider.min.css"
      onload="this.onload=null;this.rel='stylesheet'"
    >
    <noscript>
      <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glider-js@1/glider.min.css">
    </noscript>

    <!-- 9. Scripts que deben cargarse temprano (GTM) -->
    {!isLocalEnv && (
      <>
        <!-- Google Tag Manager -->
        <script is:inline>
          (function(w,d,s,l,i){
            w[l]=w[l]||[];w[l].push({'gtm.start': new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
            j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src= 'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
          })(window,document,'script','dataLayer','GTM-PH4DRF6B');
        </script>
        <!-- End Google Tag Manager -->
        <script src="/scripts/setEventsDataLayer.js" defer></script>
      </>
    )}

  </head>
  
  <body class="template-typography">
    {!isLocalEnv && (
      <>
        <!-- Google Tag Manager (noscript) -->
        <noscript>
          <iframe
            src="https://www.googletagmanager.com/ns.html?id=GTM-PH4DRF6B"
            title="Google Tag Manager"
            height="0"
            width="0"
            style="display:none;visibility:hidden">
          </iframe>
        </noscript>
        <!-- End Google Tag Manager (noscript) -->
      </>
    )}
    
    <!-- Header fixed -->
    <div class="fixed top-0 left-0 w-full z-[100]">
      <Upperbar site={site}/>
      <Navbar site={site}/>
    </div>

    <!-- ESPACIADOR MENU FIXED -->
    <div class="h-[50px] lg:h-[100px]"></div> 

    <slot />

    <StickyCta />

    <Footer site={site}/>

    <script type="module" src="/src/scripts/initLenis.ts"></script>
    
  </body>
</html>